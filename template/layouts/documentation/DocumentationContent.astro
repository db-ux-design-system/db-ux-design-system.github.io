---
import type { MarkdownHeading } from 'astro';
import { TableOfContents } from '@template/components/TableOfContents';
import { DBSection, type SemanticType } from '@db-ux/react-core-components';
import { PageHero } from '@components';

interface Props {
	headings: MarkdownHeading[];
	frontmatter: DocumentationFrontMatter;
}

const { headings, frontmatter } = Astro.props as Props;
const toc = (headings?.length ?? 0) > 0 && frontmatter.toc === true;

const badgeMap: Record<string, { text: string; semantic: SemanticType }> = {
	concept: { text: 'Concept', semantic: 'warning' },
	beta: { text: 'Beta', semantic: 'informational' },
	stable: { text: 'Stable', semantic: 'successful' },
	deprecated: { text: 'Deprecated', semantic: 'critical' },
	legacy: { text: 'Legacy', semantic: 'warning' },
};
const badge = frontmatter.status ? badgeMap[frontmatter.status] : undefined;
---

<>
	{
		toc && (
			<TableOfContents
				client:only="react"
				astro={Astro}
				headings={headings}
				tocMaxDepth={frontmatter.tocMaxDepth}
			/>
		)
	}

	<div class="dba-main-content">
		{
			(frontmatter.headline || frontmatter.description) && (
				<DBSection id={frontmatter.title} width="large" spacing="small">
					<PageHero
						headline={frontmatter.headline}
						description={frontmatter.description}
						badgeText={badge?.text}
						badgeSemantic={badge?.semantic ?? 'adaptive'}
						headlineLevel={frontmatter.headlineLevel ?? 1}
						imageSrc={frontmatter.heroImage}
						imageAlt={frontmatter.heroImageAlt}
						align={frontmatter.align}
					/>
				</DBSection>
			)
		}
		<DBSection id="main-content-section" width="large" spacing="none">
			<slot />
		</DBSection>
	</div>
</>
