---
import { DBCard, DBLink } from '@db-ux/react-core-components';
import './ResourceCards.css';

interface Resource {
	title: string;
	description: string;
	url: string;
	icon?: string;
	label?: string;
}

interface Props {
	path?: string;
	resources?: Resource[];
}

const { path, resources: customResources } = Astro.props;

const baseUrl = 'https://design-system.deutschebahn.com/core-web/review/main';

const defaultResources = [
	{
		title: 'React',
		description: 'Interactive examples and documentation.',
		url: `${baseUrl}/react-storybook${path}`,
		icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg',
	},
	{
		title: 'Vue',
		description: 'Interactive examples and documentation.',
		url: `${baseUrl}/vue-storybook${path}`,
		icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/vuejs/vuejs-original.svg',
	},
	{
		title: 'Angular',
		description: 'Interactive examples and documentation.',
		url: `${baseUrl}/angular-storybook${path}`,
		icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/angular/angular-original.svg',
	},
	{
		title: 'Web C.',
		description: 'Interactive examples and documentation.',
		url: `${baseUrl}/angular-storybook${path}`,
		icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/html5/html5-original.svg',
	},
];

const resources = customResources || defaultResources;
---

<div class="resource-cards">
	{
		resources.map((resource) => (
			<DBLink href={resource.url} target="_blank" variant="inline">
				<DBCard behavior="interactive" class="resource-card-item">
					<img
						src={resource.icon}
						alt={`Image for ${resource.title}, ${resource.description}`}
						width="32"
						height="32"
					/>
					<div class="resource-text">
						<b>{resource.title}</b>
						<p>{resource.description}</p>
					</div>
					<strong data-icon-trailing="arrow_up_right">{resource.label || 'View Storybook'}</strong>
				</DBCard>
			</DBLink>
		))
	}
</div>
