---
import { DBSection } from '@db-ux/react-core-components';
import PageHero from '@template/components/PageHero/PageHero.astro';

interface Props {
	title?: string;
	headline?: string;
	description?: string;
}

const {
	title = 'DB UX Design System',
	headline = 'A Design System designed to align teams and streamline product delivery.',
	description = 'Brings clarity to design and implementation through shared standards and reusable components.',
} = Astro.props;
---

<DBSection width="medium" spacing="medium" id="home--page-hero-section">
	<PageHero
		title={title}
		headlineLevel={1}
		headline={headline}
		description={description}
	/>
</DBSection>
