---
import { appConfig } from '@config';
import { DBCard, DBSection, DBStack } from '@db-ux/react-core-components';
import { SectionTitle, TextImage, DisabledWrapper } from '@components';

interface Props {
	sectionTitle?: string;
	sectionDescription?: string;
	foundationTitle?: string;
	foundationText?: string;
	componentsTitle?: string;
	componentsText?: string;
	extensionsTitle?: string;
	extensionsText?: string;
	patternsTitle?: string;
	patternsText?: string;
	templatesTitle?: string;
	templatesText?: string;
	comingSoonLabel?: string;
	linkPrefix?: string;
}

const {
	sectionTitle = 'A unified model for product teams',
	sectionDescription = 'Shared fundamentals, components and domain-specific extensions that support clarity and alignment.',
	foundationTitle = 'Foundation',
	foundationText = 'Shared base tokens and modes provide a stable foundation for clear and coherent interfaces.',
	componentsTitle = 'Components',
	componentsText = 'Core components ensure predictable interactions across products.',
	extensionsTitle = 'Extensions',
	extensionsText = 'Contextual standards that build on the core system to support domain-specific needs.',
	patternsTitle = 'Patterns',
	patternsText = 'Provide reusable interaction models that guide consistent behavior across products.',
	templatesTitle = 'Templates',
	templatesText = 'Offer structured starting points that speed up page creation and enforce coherent layouts.',
	comingSoonLabel = 'Coming Soon',
	linkPrefix = '',
} = Astro.props;
---

<DBSection
	width="medium"
	spacing="medium"
	aria-label="Unified model section"
	id="home--unified-model-section"
>
	<SectionTitle title={sectionTitle} description={sectionDescription} />
	<DBStack gap="large">
		<a href={`${appConfig.basePath}${linkPrefix}products-and-services/foundations`} aria-label={foundationTitle}>
			<DBCard behavior="interactive" spacing="large">
				<TextImage title={foundationTitle} imagePosition="right" imageWidth="33" imageSrc={`${appConfig.basePath}assets/Foundations-Teaser--C.png`} imageAlt="Foundations Visual" mask="fade-bottom-right">
					{foundationText}
				</TextImage>
			</DBCard>
		</a>
		<a href={`${appConfig.basePath}${linkPrefix}products-and-services/components`} aria-label={componentsTitle}>
			<DBCard behavior="interactive" spacing="large">
				<TextImage title={componentsTitle} imagePosition="right" imageWidth="33" imageSrc={`${appConfig.basePath}assets/Components-Teaser--C.png`} imageAlt="Components Visual" mask="fade-bottom-right">
					{componentsText}
				</TextImage>
			</DBCard>
		</a>
		<a href={`${appConfig.basePath}${linkPrefix}products-and-services/extensions`} aria-label={extensionsTitle}>
			<DBCard behavior="interactive" spacing="large">
				<TextImage title={extensionsTitle} imagePosition="right" imageWidth="33" imageSrc={`${appConfig.basePath}assets/Extensions-Teaser--C.png`} imageAlt="Extensions Visual" mask="fade-bottom-right">
					{extensionsText}
				</TextImage>
			</DBCard>
		</a>
		<DBStack direction="row">
			<DisabledWrapper label={comingSoonLabel} size="medium">
				<DBCard spacing="large">
					<TextImage title={patternsTitle} imagePosition="right" imageWidth="33" imageSrc={`${appConfig.basePath}assets/Patterns-Teaser--C.png`} imageAlt="Patterns Visual" mask="fade-bottom-right">
						{patternsText}
					</TextImage>
				</DBCard>
			</DisabledWrapper>
			<DisabledWrapper label={comingSoonLabel} size="medium">
				<DBCard spacing="large">
					<TextImage title={templatesTitle} imagePosition="right" imageWidth="33" imageSrc={`${appConfig.basePath}assets/Templates-Teaser--C.png`} imageAlt="Templates Visual" mask="fade-bottom-right">
						{templatesText}
					</TextImage>
				</DBCard>
			</DisabledWrapper>
		</DBStack>
	</DBStack>
</DBSection>
