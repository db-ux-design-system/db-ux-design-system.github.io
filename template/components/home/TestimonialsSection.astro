---
import { appConfig } from '@config';
import { DBSection, DBCard } from '@db-ux/react-core-components';
import { TextImage, Carousel } from '@components';

interface Props {
	quote1?: string;
	quote2?: string;
	quote3?: string;
}

const {
	quote1 = '"Since adopting the system, our teams spend less time aligning on UI details and more time solving real product problems."',
	quote2 = '"New team members ramp up faster because the system explains how we design and build our products."',
	quote3 = '"Design and development finally speak the same language — handoff feels predictable instead of repetitive."',
} = Astro.props;
---

<DBSection
	width="large"
	spacing="medium"
	aria-label="Unified model section"
	id="home--testimonials-section"
>
	<Carousel>
		<DBCard spacing="medium">
			<TextImage
				title={quote1}
				headlineLevel={2}
				imagePosition="left"
				imageWidth="33"
				rounded={true}
				imageSrc={`${appConfig.basePath}assets/people/Finn-Hoffmeister--C.jpg`}
				imageAlt="Finn Hoffmeister"
				textGap="2xl"
			>
				Finn Hoffmeister <br />
				Product Owner @ DB Systel
			</TextImage>
		</DBCard>
		<DBCard spacing="medium">
			<TextImage
				title={quote2}
				headlineLevel={2}
				imagePosition="left"
				imageWidth="33"
				rounded={true}
				imageSrc={`${appConfig.basePath}assets/people/Patrick-Weber--C.jpg`}
				imageAlt="Tobias Oberpaul"
				textGap="2xl"
			>
				Patrick Weber <br />
				Design Lead @ DB Fernverkehr
			</TextImage>
		</DBCard>
		<DBCard spacing="medium">
			<TextImage
				title={quote3}
				headlineLevel={2}
				imagePosition="left"
				imageWidth="33"
				rounded={true}
				imageSrc={`${appConfig.basePath}assets/people/Danny-Koppenhagen--C.jpg`}
				imageAlt="Danny Koppenhagen"
				textGap="2xl"
			>
				Danny Koppenhagen <br />
				Frontend Architect @ DB Systel
			</TextImage>
		</DBCard>
	</Carousel>
</DBSection>
