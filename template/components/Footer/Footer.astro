---
import { DBLink, DBStack } from '@db-ux/react-core-components';
import './Footer.css';

const currentPath = Astro.url?.pathname ?? '';
const isDE = currentPath.startsWith('/de/') || currentPath === '/de';
const imprintLabel = isDE ? 'Impressum' : 'Imprint';
const privacyLabel = isDE ? 'Datenschutz' : 'Privacy';
const linkPrefix = isDE ? '/de' : '';
---

<footer class="footer">
	<DBStack direction="row" gap="medium">
		<DBLink variant="inline" href={`${linkPrefix}/legal/imprint`}> {imprintLabel} </DBLink>
		<DBLink variant="inline" href={`${linkPrefix}/legal/privacy`}> {privacyLabel} </DBLink>
	</DBStack>
</footer>
