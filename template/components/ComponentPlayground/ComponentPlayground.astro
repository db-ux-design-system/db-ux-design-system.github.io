									action = `const field = document.getElementById('playground-input-field'); if(field) { if(this.checked) field.setAttribute('readonly', ''); else field.removeAttribute('readonly'); }`;
								} else if (prop.name === 'checked') {
									const targetId = [
										'playground-switch',
