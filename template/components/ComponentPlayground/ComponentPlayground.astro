									action = `const target = document.getElementById('${targetId}'); target.checked = this.checked; if(this.checked) target.setAttribute('checked', ''); else target.removeAttribute('checked');`;
								} else if (
									['playground-switch', 'playground-radio', 'playground-checkbox'].includes(
										config.elementId,
									) &&
									(prop.name === 'show-label' || prop.name === 'showLabel')
								) {
									action = `const label = document.getElementById('${config.elementId}-label'); if(this.checked) label.style.display = ''; else label.style.display = 'none';`;
								} else if (
									config.elementId === 'playground-select' &&
									['showLabel', 'show-label'].includes(prop.name)
								) {
									action = `const wrapper = document.getElementById('${config.elementId}'); if(wrapper) wrapper.setAttribute('data-hide-label', this.checked ? 'false' : 'true');`;
								} else if (
									config.elementId === 'playground-input' &&
									['showLabel', 'show-label'].includes(prop.name)
								) {
									action = `const label = document.getElementById('playground-input-label'); if(label) label.style.display = this.checked ? '' : 'none';`;
								} else if (
									config.elementId === 'playground-select' &&
									['showMessage', 'show-message'].includes(prop.name)
								) {
									action = `const message = document.getElementById('playground-select-message'); if(message) message.style.display = this.checked ? '' : 'none'; this.closest('.controls-area-content').querySelectorAll('[data-depends-on="showMessage"],[data-depends-on="show-message"]').forEach(function(el){ el.style.display = this.checked ? '' : 'none'; }.bind(this));`;
								} else if (
									config.elementId === 'playground-select' &&
									['show-icon', 'showIcon'].includes(prop.name)
								) {
									action = `const el = document.getElementById('playground-select'); var ctrl = document.getElementById('playground-select-icon-control'); if(this.checked) { el.setAttribute('data-show-icon', 'true'); if(ctrl && ctrl.value) el.setAttribute('data-icon', ctrl.value); } else { el.removeAttribute('data-show-icon'); el.removeAttribute('data-icon'); } this.closest('.controls-area-content').querySelectorAll('[data-depends-on="show-icon"],[data-depends-on="showIcon"]').forEach(function(dep){ dep.style.display = this.checked ? '' : 'none'; }.bind(this));`;
								} else if (
									config.elementId === 'playground-tag' &&
									['show-icon / showIcon', 'show-icon', 'showIcon'].includes(prop.name)
								) {
									action = `const el = document.getElementById('playground-tag'); var t2 = document.getElementById('playground-tag-2'); var ctrl = document.getElementById('playground-tag-icon-control'); if(this.checked) { el.setAttribute('data-show-icon', 'true'); if(ctrl && ctrl.value) el.setAttribute('data-icon', ctrl.value); else el.setAttribute('data-icon', 'star'); if(t2) { t2.setAttribute('data-show-icon', 'true'); if(ctrl && ctrl.value) t2.setAttribute('data-icon', ctrl.value); else t2.setAttribute('data-icon', 'star'); } } else { el.removeAttribute('data-show-icon'); el.removeAttribute('data-icon'); if(t2) { t2.removeAttribute('data-show-icon'); t2.removeAttribute('data-icon'); } } this.closest('.controls-area-content').querySelectorAll('[data-depends-on="show-icon"],[data-depends-on="showIcon"],[data-depends-on^="show-icon / showIcon"]').forEach(function(dep){ dep.style.display = this.checked ? '' : 'none'; }.bind(this));`;
								} else if (
									config.elementId === 'playground-input' &&
									['showMessage', 'show-message'].includes(prop.name)
								) {
									action = `const message = document.getElementById('playground-input-message'); if(message) message.style.display = this.checked ? '' : 'none'; this.closest('.controls-area-content').querySelectorAll('[data-depends-on="showMessage"],[data-depends-on="show-message"]').forEach(function(el){ el.style.display = this.checked ? '' : 'none'; }.bind(this));`;
								} else if (
									config.elementId === 'playground-textarea' &&
									['showMessage', 'show-message'].includes(prop.name)
								) {
									action = `const message = document.getElementById('playground-textarea-message'); if(message) message.style.display = this.checked ? '' : 'none'; this.closest('.controls-area-content').querySelectorAll('[data-depends-on="showMessage"],[data-depends-on="show-message"]').forEach(function(el){ el.style.display = this.checked ? '' : 'none'; }.bind(this));`;
								} else if (
									config.elementId === 'playground-textarea' &&
									['show-label', 'showLabel'].includes(prop.name)
								) {
									action = `const label = document.getElementById('playground-textarea-label'); if(label) label.style.display = this.checked ? '' : 'none';`;
								} else if (config.elementId === 'playground-textarea' && prop.name === 'readonly') {
									action = `const field = document.getElementById('playground-textarea-field'); if(field) { if(this.checked) field.setAttribute('readonly', ''); else field.removeAttribute('readonly'); }`;
								} else if (
									config.elementId === 'playground-checkbox' &&
									['showMessage', 'show-message'].includes(prop.name)
								) {
									action = `const message = document.getElementById('playground-checkbox-message'); if(message) message.style.display = this.checked ? '' : 'none'; this.closest('.controls-area-content').querySelectorAll('[data-depends-on="showMessage"],[data-depends-on="show-message"]').forEach(function(el){ el.style.display = this.checked ? '' : 'none'; }.bind(this));`;
								} else if (
									config.elementId === 'playground-switch' &&
									['showMessage', 'show-message'].includes(prop.name)
								) {
									action = `const message = document.getElementById('playground-switch-message'); if(message) message.style.display = this.checked ? '' : 'none'; this.closest('.controls-area-content').querySelectorAll('[data-depends-on="showMessage"],[data-depends-on="show-message"]').forEach(function(el){ el.style.display = this.checked ? '' : 'none'; }.bind(this));`;
								} else if (
									config.elementId === 'playground-switch' &&
									prop.name === 'required'
								) {
									action = `const field = document.getElementById('playground-switch-input'); if(field) { if(this.checked) field.setAttribute('required', ''); else field.removeAttribute('required'); }`;
								} else if (
									config.elementId === 'playground-switch' &&
									(prop.name === 'visual-aid' || prop.name === 'visualAid')
								) {
									action = `const el = document.getElementById('playground-switch-label-wrapper'); if(this.checked) { el.setAttribute('data-visual-aid', 'true'); var ctrlL = document.getElementById('playground-switch-icon-leading-control'); if(ctrlL && ctrlL.value) el.setAttribute('data-icon-leading', ctrlL.value); var ctrlT = document.getElementById('playground-switch-icon-trailing-control'); if(ctrlT && ctrlT.value) el.setAttribute('data-icon-trailing', ctrlT.value); } else { el.removeAttribute('data-visual-aid'); el.removeAttribute('data-icon-leading'); el.removeAttribute('data-icon-trailing'); } this.closest('.controls-area-content').querySelectorAll('[data-depends-on="visual-aid"],[data-depends-on="visualAid"]').forEach(function(dep){ dep.style.display = this.checked ? '' : 'none'; }.bind(this));`;
								} else if (config.elementId === 'playground-select' && prop.name === 'required') {
									action = `const field = document.getElementById('playground-select-field'); if(field) { if(this.checked) field.setAttribute('required', ''); else field.removeAttribute('required'); }`;
								} else if (
									config.elementId === 'playground-input' &&
									['show-icon-leading', 'showIconLeading'].includes(prop.name)
								) {
									action = `const el = document.getElementById('playground-input'); var ctrl = document.getElementById('playground-input-icon-leading-control'); if(this.checked) { el.setAttribute('data-show-icon', 'true'); if(ctrl && ctrl.value) el.setAttribute('data-icon', ctrl.value); } else { el.removeAttribute('data-show-icon'); el.removeAttribute('data-icon'); } this.closest('.controls-area-content').querySelectorAll('[data-depends-on="show-icon-leading"],[data-depends-on="showIconLeading"]').forEach(function(dep){ dep.style.display = this.checked ? '' : 'none'; }.bind(this));`;
								} else if (
									config.elementId === 'playground-input' &&
									['show-icon-trailing', 'showIconTrailing'].includes(prop.name)
								) {
									action = `const el = document.getElementById('playground-input'); var ctrl = document.getElementById('playground-input-icon-trailing-control'); if(this.checked) { el.setAttribute('data-show-icon-trailing', 'true'); if(ctrl && ctrl.value) el.setAttribute('data-icon-trailing', ctrl.value); } else { el.removeAttribute('data-show-icon-trailing'); el.removeAttribute('data-icon-trailing'); } this.closest('.controls-area-content').querySelectorAll('[data-depends-on="show-icon-trailing"],[data-depends-on="showIconTrailing"]').forEach(function(dep){ dep.style.display = this.checked ? '' : 'none'; }.bind(this));`;
								} else if (
									config.elementId === 'playground-checkbox' &&
									prop.name === 'indeterminate'
								) {
									action = `const target = document.getElementById('playground-checkbox-input'); target.indeterminate = this.checked;`;
								} else if (config.elementId === 'demo-notification' && prop.name === 'closeable') {
									action = `var n = document.getElementById('demo-notification'); var btn = document.getElementById('notification-close'); if(this.checked) { if(!btn) { btn = document.createElement('button'); btn.id = 'notification-close'; btn.className = 'db-button'; btn.type = 'button'; btn.setAttribute('data-icon','cross'); btn.setAttribute('data-size','small'); btn.setAttribute('data-variant','ghost'); btn.setAttribute('data-no-text','true'); btn.textContent = 'Close'; n.appendChild(btn); } } else { if(btn) btn.remove(); } var lvSelect = document.getElementById('demo-notification-link-variant-select'); if(lvSelect) lvSelect.dispatchEvent(new Event('change'));`;
								} else if (
									config.elementId === 'demo-notification' &&
									(prop.name === 'show-timestamp' || prop.name === 'showTimestamp')
								) {
									action = `var n = document.getElementById('demo-notification'); var ts = document.getElementById('notification-timestamp'); if(this.checked) { if(!ts) { ts = document.createElement('span'); ts.id = 'notification-timestamp'; var ctrl = document.querySelector('#demo-notification-timestamp-control'); ts.textContent = ctrl ? ctrl.value : '10 min. ago'; var btn = document.getElementById('notification-close'); n.insertBefore(ts, btn); } } else { if(ts) ts.remove(); } var lvSelect = document.getElementById('demo-notification-link-variant-select'); if(lvSelect) lvSelect.dispatchEvent(new Event('change')); this.closest('.controls-area-content').querySelectorAll('[data-depends-on="show-timestamp"],[data-depends-on="showTimestamp"]').forEach(function(el){ el.style.display = this.checked ? '' : 'none'; }.bind(this));`;
								} else if (
									config.elementId === 'demo-navigation-item' &&
									['show-icon', 'showIcon'].includes(prop.name)
								) {
									action = `const item = document.getElementById('${config.elementId}'); if(this.checked) item.setAttribute('data-show-icon', 'true'); else item.setAttribute('data-show-icon', 'false');`;
								} else if (
									config.elementId === 'playground-link' &&
									['show-icon', 'showIcon'].includes(prop.name)
								) {
									action = `const link = document.getElementById('playground-link'); if(this.checked) link.removeAttribute('data-show-icon-trailing'); else link.setAttribute('data-show-icon-trailing', 'false');`;
								} else if (
									config.elementId === 'demo-infotext' &&
									prop.name === 'show-icon / showIcon'
								) {
									action = `const infotext = document.getElementById('demo-infotext'); if(this.checked) infotext.setAttribute('data-show-icon-leading', 'true'); else infotext.setAttribute('data-show-icon-leading', 'false');`;
								} else if (config.elementId === 'demo-navigation-item' && prop.name === 'active') {
									action = `const item = document.getElementById('${config.elementId}'); if(this.checked) item.setAttribute('data-active', 'true'); else item.removeAttribute('data-active');`;
								} else if (config.elementId === 'demo-navigation-item' && prop.name === 'wrap') {
									action = `const item = document.getElementById('${config.elementId}'); if(this.checked) item.setAttribute('data-wrap', 'true'); else item.removeAttribute('data-wrap');`;
								} else if (
									config.elementId === 'demo-navigation-item' &&
									prop.name === 'disabled'
								) {
									action = `const item = document.getElementById('${config.elementId}'); const link = document.getElementById('navigation-item-link'); if(this.checked) { item.setAttribute('aria-disabled', 'true'); link.setAttribute('aria-disabled', 'true'); } else { item.removeAttribute('aria-disabled'); link.removeAttribute('aria-disabled'); }`;
								} else if (
									config.elementId === 'demo-notification' &&
									(prop.name === 'show-headline' || prop.name === 'showHeadline')
								) {
									action = `var n = document.getElementById('demo-notification'); var h = document.getElementById('notification-headline'); if(this.checked) { if(!h) { h = document.createElement('header'); h.id = 'notification-headline'; var ctrl = document.querySelector('#demo-notification-headline-control'); h.textContent = ctrl ? ctrl.value : (n.getAttribute('data-headline') || 'Headline'); n.insertBefore(h, n.firstChild); } } else { if(h) h.remove(); } var lvSelect = document.getElementById('demo-notification-link-variant-select'); if(lvSelect) lvSelect.dispatchEvent(new Event('change'));`;
								} else if (
									config.elementId === 'demo-notification' &&
									(prop.name === 'show-icon' || prop.name === 'showIcon')
								) {
									action = `var n = document.getElementById('demo-notification'); var sem = n.getAttribute('data-semantic'); var styleEl = document.getElementById('notification-icon-style'); if(this.checked) { styleEl.textContent = ''; if(sem === 'adaptive') { n.setAttribute('data-icon', 'information_circle'); } else { n.removeAttribute('data-icon'); } } else { styleEl.textContent = '#demo-notification::before { display: none !important; }'; n.removeAttribute('data-icon'); }`;
								} else if (
									config.elementId === 'playground-tag' &&
									['no-text / noText', 'no-text', 'noText'].includes(prop.name)
								) {
									action = `var el = document.getElementById('playground-tag'); var t2 = document.getElementById('playground-tag-2'); var iconCtrl = document.getElementById('playground-tag-icon-control'); var showIconCb = this.closest('.controls-area-content').querySelector('input[type=checkbox][onchange*="data-show-icon"]'); var showIconWrapper = showIconCb ? (showIconCb.closest('[data-depends-on]') || showIconCb.closest('label.db-switch')) : null; if(this.checked) { el.setAttribute('data-no-text', 'true'); if(t2) t2.setAttribute('data-no-text', 'true'); if(iconCtrl && !iconCtrl.value) iconCtrl.value = 'star'; var iconVal = iconCtrl ? iconCtrl.value : 'star'; el.setAttribute('data-icon', iconVal); el.setAttribute('data-show-icon', 'true'); if(t2) { t2.setAttribute('data-icon', iconVal); t2.setAttribute('data-show-icon', 'true'); } this.closest('.controls-area-content').querySelectorAll('[data-depends-on^="show-icon / showIcon"],[data-depends-on="show-icon"],[data-depends-on="showIcon"]').forEach(function(dep){ dep.style.display = ''; }); if(showIconWrapper) showIconWrapper.style.display = 'none'; } else { el.removeAttribute('data-no-text'); if(t2) t2.removeAttribute('data-no-text'); if(showIconWrapper) showIconWrapper.style.display = ''; var showIconChecked = showIconCb ? showIconCb.checked : false; if(!showIconChecked) { el.removeAttribute('data-icon'); el.removeAttribute('data-show-icon'); if(t2) { t2.removeAttribute('data-icon'); t2.removeAttribute('data-show-icon'); } this.closest('.controls-area-content').querySelectorAll('[data-depends-on^="show-icon / showIcon"],[data-depends-on="show-icon"],[data-depends-on="showIcon"]').forEach(function(dep){ dep.style.display = 'none'; }); } }`;
								} else if (
									config.elementId === 'playground-tag' &&
									['show-check-state / showCheckState', 'show-check-state', 'showCheckState'].includes(prop.name)
								) {
									action = `var el = document.getElementById('playground-tag'); var t2 = document.getElementById('playground-tag-2'); if(this.checked) { el.setAttribute('data-show-check-state', 'true'); if(t2) t2.setAttribute('data-show-check-state', 'true'); } else { el.removeAttribute('data-show-check-state'); if(t2) t2.removeAttribute('data-show-check-state'); }`;
								} else {
									let setsOnTrueAction = '';
									let setsOnFalseAction = '';
									if (prop.setsOnTrue) {
										// Build condition: only set if specified fields are empty
										let condition = 'true';
										if (prop.setsOnTrueOnlyIfEmpty) {
											const checks = prop.setsOnTrueOnlyIfEmpty.map((field: string) => {
												const ctrlId = `${config.elementId}-${field}-control`;
												return `(!document.getElementById('${ctrlId}') || !document.getElementById('${ctrlId}').value)`;
											});
											condition = checks.join(' && ');
										}
										for (const [key, val] of Object.entries(prop.setsOnTrue)) {
											const setAttr = nativeAttributes.includes(key) ? key : `data-${key}`;
											setsOnTrueAction += `if(${condition}) { var el = document.getElementById('${config.elementId}'); el.setAttribute('${setAttr}', '${val}'); var ctrl = document.getElementById('${config.elementId}-${key}-control'); if(ctrl) ctrl.value = '${val}'; }`;
											setsOnFalseAction += `var ctrl = document.getElementById('${config.elementId}-${key}-control'); if(ctrl && ctrl.value === '${val}') { document.getElementById('${config.elementId}').removeAttribute('${setAttr}'); ctrl.value = ''; }`;
										}
									}
									const depSelector = prop.alternativeName
										? `[data-depends-on="${prop.name}"],[data-depends-on="${prop.alternativeName}"]`
										: `[data-depends-on="${prop.name}"]`;
									action = `if(this.checked) { document.getElementById('${config.elementId}').setAttribute('data-${prop.name}', 'true'); ${setsOnTrueAction} } else { document.getElementById('${config.elementId}').setAttribute('data-${prop.name}', 'false'); ${setsOnFalseAction} } this.closest('.controls-area-content').querySelectorAll('${depSelector}').forEach(function(el){ el.style.display = this.checked ? '' : 'none'; }.bind(this));`;
								}

								return depAttr ? (
									<div data-depends-on={depAttr} style={depHidden ? 'display:none;' : ''}>
										<label class="db-switch">
											<input
												type="checkbox"
												role="switch"
												checked={prop.defaultValue}
												onchange={action}
											/>
											{prop.label}
										</label>
									</div>
								) : (
									<label class="db-switch">
										<input
											type="checkbox"
											role="switch"
											checked={prop.defaultValue}
											onchange={action}
										/>
										{prop.label}
									</label>
								);
							}
						})}
				</div>
			</div>
		)
	}
</div>
