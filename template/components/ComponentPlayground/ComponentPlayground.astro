---
import './ComponentPlayground.css';
import { DBAccordionItem } from '@db-ux/react-core-components';
import ShellExample from '@template/components/ShellExample/ShellExample.tsx';
import TooltipExample from '@template/components/TooltipExample/TooltipExample.tsx';
interface Props {
	config: any;
	component: any;
}

const { config, component: Component } = Astro.props;

// Native HTML attributes that should not use data- prefix
const nativeAttributes = [
	'label',
	'placeholder',
	'type',
	'disabled',
	'required',
	'readonly',
	'value',
	'name',
	'id',
];
---

<div class="component-playground">
	<div class="preview-area">
		{
			config.elementId === 'playground-badge' ? (
				<div class="badge-container">
					<span>List Item</span>
					<Component {...config.defaultProps} id={config.elementId}>
						{config.textElementId && <span id={config.textElementId}>{config.defaultText}</span>}
						{!config.textElementId && config.defaultText}
					</Component>
				</div>
			) : config.elementId === 'demo-accordion' ? (
				<Component {...config.defaultProps} id={config.elementId}>
					<DBAccordionItem headlinePlain={`${config.defaultText} 1`}>
						{config.defaultText}
					</DBAccordionItem>
					<DBAccordionItem headlinePlain={`${config.defaultText} 2`}>
						{config.defaultText} 2
					</DBAccordionItem>
				</Component>
			) : config.elementId === 'playground-input' ? (
				<div class="db-input" id={config.elementId}>
					<label id="playground-input-label">{config.defaultProps.label || 'Label'}</label>
					<input
						id="playground-input-field"
						aria-invalid="false"
						type={config.defaultProps.type || 'text'}
						placeholder={config.defaultProps.placeholder || ''}
						disabled={config.defaultProps.disabled}
					/>
					<span
						id="playground-input-message"
						class="db-infotext"
						data-size="small"
						data-show-icon-leading="true"
						style="display: none;"
					>
						{config.properties.find((p: any) => p.name === 'message')?.defaultValue || 'Message'}
					</span>
					<span
						id="playground-input-infotext-valid"
						class="db-infotext"
						data-semantic="successful"
						data-size="small"
						data-show-icon-leading="true"
						style="display: none;"
					>
						{config.properties.find(
							(p: any) => p.name === 'validMessage' || p.name === 'valid-message',
						)?.defaultValue || ''}
					</span>
					<span
						id="playground-input-infotext"
						class="db-infotext"
						data-semantic="critical"
						data-size="small"
						data-show-icon-leading="true"
						style="display: none;"
					>
						{config.properties.find(
							(p: any) => p.name === 'invalidMessage' || p.name === 'invalid-message',
						)?.defaultValue || ''}
					</span>
					<span data-visually-hidden="true" role="status" />
				</div>
			) : config.elementId === 'playground-switch' ? (
				<div id={config.elementId} style="display: flex; flex-direction: column; gap: var(--db-spacing-fixed-2xs);">
					<style id="switch-validation-style">{``}</style>
					<label class="db-switch" id="playground-switch-label-wrapper">
						<input
							id="playground-switch-input"
							type="checkbox"
							role="switch"
							checked={config.defaultProps.checked}
							disabled={config.defaultProps.disabled}
						/>
						<span id="playground-switch-label">Enable notifications</span>
					</label>
					<span
						id="playground-switch-message"
						class="db-infotext"
						data-size="small"
						data-show-icon-leading="true"
						style="display: none;"
					>
						Message
					</span>
					<span
						id="playground-switch-infotext-valid"
						class="db-infotext"
						data-semantic="successful"
						data-size="small"
						data-show-icon-leading="true"
						style="display: none;"
					>
						Terms accepted
					</span>
					<span
						id="playground-switch-infotext"
						class="db-infotext"
						data-semantic="critical"
						data-size="small"
						data-show-icon-leading="true"
						style="display: none;"
					>
						Please accept the terms
					</span>
				</div>
			) : config.elementId === 'playground-radio' ? (
				<label class="db-radio" id={config.elementId}>
					<input
						id="playground-radio-input"
						type="radio"
						checked={config.defaultProps.checked}
						disabled={config.defaultProps.disabled}
						onchange={
							"var ctrls = document.querySelectorAll('.controls-area input[type=checkbox]'); ctrls.forEach(function(c){ if(c.onchange && c.onchange.toString().includes('target.checked')) c.checked = this.checked; }.bind(this));"
						}
					/>
					<span id="playground-radio-label">Label</span>
				</label>
			) : config.elementId === 'playground-checkbox' ? (
				<div class="db-checkbox" id={config.elementId}>
					<label>
						<input
							id="playground-checkbox-input"
							type="checkbox"
							checked={config.defaultProps.checked}
							disabled={config.defaultProps.disabled}
						/>
						<span id="playground-checkbox-label">Accept terms</span>
					</label>
					<span
						id="playground-checkbox-message"
						class="db-infotext"
						data-size="small"
						data-show-icon-leading="true"
						style="display: none;"
					>
						Message
					</span>
					<span
						id="playground-checkbox-infotext-valid"
						class="db-infotext"
						data-semantic="successful"
						data-size="small"
						data-show-icon-leading="true"
						style="display: none;"
					>
						Terms accepted
					</span>
					<span
						id="playground-checkbox-infotext"
						class="db-infotext"
						data-semantic="critical"
						data-size="small"
						data-show-icon-leading="true"
						style="display: none;"
					>
						Please accept the terms
					</span>
				</div>
			) : config.elementId === 'demo-navigation' ? (
				<nav class="db-navigation">
					<menu>
						<li class="db-navigation-item">
							<a href="#" aria-current="page">
								Navigation Item 1
							</a>
						</li>
						<li class="db-navigation-item">
							<a href="#">Navigation Item 2</a>
						</li>
						<li class="db-navigation-item">
							<a href="#">Navigation Item 3</a>
						</li>
					</menu>
				</nav>
			) : config.elementId === 'demo-navigation-item' ? (
				<nav class="db-navigation">
					<menu>
						<li class="db-navigation-item" id={config.elementId} data-width="auto">
							<a id="navigation-item-link" href="#">
								Navigation Item
							</a>
						</li>
					</menu>
				</nav>
			) : config.elementId === 'demo-notification' ? (
				<>
					<style id="notification-icon-style">{``}</style>
					<article
						class="db-notification"
						id={config.elementId}
						data-semantic={config.defaultProps.semantic}
						data-variant={config.defaultProps.variant}
						data-headline={config.defaultProps.headline}
						data-link-variant="block"
						data-icon="information_circle"
					>
						<header id="notification-headline">{config.defaultProps.headline || 'Headline'}</header>
						<p />
						<p id="notification-text">{config.defaultText}</p>
						<p />
						<a
							id="notification-link"
							class="db-link"
							href="#"
							data-size="medium"
						>
							Link
						</a>
						<button
							id="notification-close"
							class="db-button"
							type="button"
							data-icon="cross"
							data-size="small"
							data-variant="ghost"
							data-no-text="true"
							hidden={
								config.properties.find((p: any) => p.name === 'closeable')?.defaultValue === false
							}
						>
							Close
						</button>
					</article>
				</>
			) : config.elementId === 'playground-select' ? (
				<div class="db-select" id={config.elementId} data-hide-label="false" data-variant="above">
					<label id="playground-select-label" for="playground-select-field">
						{config.defaultProps.label || 'Label'}
					</label>
					<select
						id="playground-select-field"
						onchange={
							"var w = document.getElementById('playground-select'); if(w.getAttribute('data-variant') === 'floating') { if(this.value) { w.removeAttribute('data-label-hidden'); } else { w.setAttribute('data-label-hidden', 'true'); } }"
						}
					>
						<option id="playground-select-placeholder" value="" hidden selected>
							{config.defaultProps.placeholder || 'Choose an option'}
						</option>
						<option value="de">Germany</option>
						<option value="fr">France</option>
						<option value="it">Italy</option>
						<option value="es">Spain</option>
					</select>
					<span
						id="playground-select-message"
						class="db-infotext"
						data-size="small"
						data-show-icon-leading="true"
						style="display: none;"
					>
						Message
					</span>
					<span
						id="playground-select-infotext-valid"
						class="db-infotext"
						data-semantic="successful"
						data-size="small"
						data-show-icon-leading="true"
						style="display: none;"
					>
						Valid selection
					</span>
					<span
						id="playground-select-infotext"
						class="db-infotext"
						data-semantic="critical"
						data-size="small"
						data-show-icon-leading="true"
						style="display: none;"
					>
						Please select a valid option
					</span>
					<span data-visually-hidden="true" role="status" />
				</div>
			) : config.elementId === 'playground-textarea' ? (
				<div class="db-textarea" id={config.elementId} data-variant={config.defaultProps.variant}>
					<label id="playground-textarea-label">{config.defaultProps.label || 'Message'}</label>
					<textarea
						id="playground-textarea-field"
						aria-invalid="false"
						placeholder={config.defaultProps.placeholder || ''}
						disabled={config.defaultProps.disabled}
						required={config.defaultProps.required}
						rows="4"
						data-resize="none"
					/>
					<span
						id="playground-textarea-message"
						class="db-infotext"
						data-size="small"
						data-show-icon-leading="true"
						style="display: none;"
					>
						Message
					</span>
					<span
						id="playground-textarea-infotext-valid"
						class="db-infotext"
						data-semantic="successful"
						data-size="small"
						data-show-icon-leading="true"
						style="display: none;"
					>
						{config.properties.find(
							(p: any) => p.name === 'valid-message' || p.name === 'validMessage',
						)?.defaultValue || 'Valid input'}
					</span>
					<span
						id="playground-textarea-infotext"
						class="db-infotext"
						data-semantic="critical"
						data-size="small"
						data-show-icon-leading="true"
						style="display: none;"
					>
						{config.properties.find(
							(p: any) => p.name === 'invalid-message' || p.name === 'invalidMessage',
						)?.defaultValue || 'Please enter a valid message'}
					</span>
					<span data-visually-hidden="true" role="status" />
				</div>
			) : config.elementId === 'playground-header' ? (
				<ShellExample />
			) : config.elementId === 'demo-tooltip' ? (
				<TooltipExample
					text={config.defaultText}
					placement={config.defaultProps.placement}
					animation={config.defaultProps.animation}
					showArrow={config.defaultProps.showArrow}
					emphasis={config.defaultProps.emphasis}
					width={config.defaultProps.width}
				/>
			) : config.elementId === 'demo-drawer' ? (
				<>
					<button
						class="db-button"
						type="button"
						data-variant="primary"
						onclick={
							"var d = document.getElementById('demo-drawer'); d.showModal(); var cb = document.querySelector('.controls-area input[type=checkbox][onchange*=showModal]'); if(cb) cb.checked = true;"
						}
					>
						Open Drawer
					</button>
					<dialog
						class="db-drawer"
						id={config.elementId}
						data-backdrop={config.defaultProps.backdrop}
						data-direction={config.defaultProps.direction}
						onclick={
							"if(event.target === this) { this.close(); var cb = document.querySelector('.controls-area input[type=checkbox][onchange*=showModal]'); if(cb) cb.checked = false; }"
						}
					>
						<article class="db-drawer-container" data-direction={config.defaultProps.direction}>
							<header class="db-drawer-header">
								<div class="db-drawer-header-text">
									<header id="drawer-header-content">Drawer Title</header>
								</div>
								<button
									class="db-button button-close-drawer"
									type="button"
									data-icon="cross"
									data-variant="ghost"
									data-no-text="true"
									onclick={
										"var d = document.getElementById('demo-drawer'); d.close(); var cb = document.querySelector('.controls-area input[type=checkbox][onchange*=showModal]'); if(cb) cb.checked = false;"
									}
								>
									Close
								</button>
							</header>
							<div class="db-drawer-content" id="drawer-content">
								<p>This is the drawer content. You can add any content here.</p>
							</div>
						</article>
					</dialog>
				</>
			) : config.elementId === 'playground-tag' ? (
				<div style="display: flex; gap: var(--db-spacing-fixed-xs); flex-wrap: wrap; align-items: center;">
					<div
						class="db-tag"
						id={config.elementId}
						data-behavior={config.defaultProps.behavior}
						data-semantic={config.defaultProps.semantic}
						data-emphasis={config.defaultProps.emphasis}
					>
						<span id="playground-tag-text">{config.defaultText}</span>
						{config.defaultProps.behavior === 'removable' && (
							<button
								class="db-button db-tab-remove-button"
								data-icon="cross"
								data-size="small"
								data-no-text="true"
								data-variant="ghost"
								type="button"
							>
								<i
									role="tooltip"
									aria-hidden="true"
									data-gap="true"
									class="db-tooltip"
									id="playground-tag-tooltip"
									data-animation="true"
									data-show-arrow="true"
								>
									Remove
								</i>
							</button>
						)}
					</div>
				</div>
			) : config.elementId === 'demo-infotext' ? (
				<span
					class="db-infotext"
					id={config.elementId}
					data-semantic={config.defaultProps.semantic}
					data-size={config.defaultProps.size}
					data-show-icon-leading={String(config.defaultProps.showIcon)}
				>
					<span id="demo-infotext-text">{config.defaultText}</span>
				</span>
			) : (
				<Component {...config.defaultProps} id={config.elementId}>
					{config.textElementId && <span id={config.textElementId}>{config.defaultText}</span>}
					{!config.textElementId && config.defaultText}
				</Component>
			)
		}
	</div>

	{
		config.properties.filter((prop: any) => prop.showInPlayground !== false).length > 0 && (
			<div class="controls-area">
				<div class="controls-area-content" data-density="functional">
					{config.properties
						.filter((prop: any) => prop.showInPlayground !== false)
						.map((prop: any) => {
							/* dependsOn: compute whether this control should be initially hidden
							 * String form: dependsOn: 'show-message' (checkbox toggle)
							 * Object form: dependsOn: { prop: 'validation', value: 'invalid' } (select value match)
							 */
							const depCfg = prop.dependsOn;
							const isObjectDep = depCfg && typeof depCfg === 'object';
							const depPropName = isObjectDep ? depCfg.prop : depCfg;
							const depValue = isObjectDep ? depCfg.value : null;
							const depNotValue = isObjectDep ? depCfg.notValue : null;
							const depParent = depPropName
								? config.properties.find(
										(p: any) => p.name === depPropName || p.alternativeName === depPropName,
									)
								: null;
							const currentParentValue = depParent
								? depParent.defaultValue ||
									depParent.options?.find((o: any) => o.default)?.value ||
									''
								: '';
							const depHidden =
								depPropName && depParent
									? isObjectDep
										? depNotValue
											? currentParentValue === depNotValue
											: currentParentValue !== depValue
										: !depParent.defaultValue
									: false;
							const depAttr = depPropName
								? isObjectDep
									? depNotValue
										? `${depPropName}:!${depNotValue}`
										: `${depPropName}:${depValue}`
									: depPropName
								: null;

							if (prop.type === 'select') {
								const attrName = nativeAttributes.includes(prop.name)
									? prop.name
									: `data-${prop.name}`;
								const targetId =
									config.elementId === 'playground-input' && nativeAttributes.includes(prop.name)
										? prop.name === 'label'
											? 'playground-input-label'
											: 'playground-input-field'
										: config.elementId;
								let updateAction;
								if (config.elementId === 'demo-drawer' && prop.name === 'direction') {
									updateAction = `const drawer = document.getElementById('demo-drawer'); const container = drawer.querySelector('.db-drawer-container'); drawer.setAttribute('data-direction', this.value); container.setAttribute('data-direction', this.value);`;
								} else if (config.elementId === 'demo-drawer' && prop.name === 'backdrop') {
									updateAction = `document.getElementById('demo-drawer').setAttribute('data-backdrop', this.value);`;
								} else if (config.elementId === 'demo-drawer' && prop.name === 'spacing') {
									updateAction = `document.getElementById('demo-drawer').querySelector('.db-drawer-container').setAttribute('data-spacing', this.value);`;
								} else if (config.elementId === 'playground-input' && prop.name === 'label') {
									updateAction = `document.getElementById('${targetId}').textContent = this.value;`;
								} else if (config.elementId === 'playground-input' && prop.name === 'variant') {
									updateAction = `var wrapper = document.getElementById('playground-input'); wrapper.setAttribute('data-variant', this.value); var label = document.getElementById('playground-input-label'); if(label && this.value !== 'above') { label.style.display = ''; var area2 = this.closest('.controls-area-content'); if(area2) { var slCb = area2.querySelector('input[type=checkbox][onchange*="playground-input-label"]'); if(slCb) slCb.checked = true; } } var area = this.closest('.controls-area-content'); if(area) area.querySelectorAll('[data-depends-on^="variant:"]').forEach(function(el){ var v = el.getAttribute('data-depends-on').split(':')[1]; if(v.charAt(0)==='!') { el.style.display = (this.value !== v.slice(1)) ? '' : 'none'; } else { el.style.display = (v === this.value) ? '' : 'none'; } }.bind(this));`;
								} else if (config.elementId === 'playground-textarea' && prop.name === 'variant') {
									updateAction = `var wrapper = document.getElementById('playground-textarea'); wrapper.setAttribute('data-variant', this.value); var label = document.getElementById('playground-textarea-label'); if(label && this.value !== 'above') label.style.display = ''; var area = this.closest('.controls-area-content'); if(area) area.querySelectorAll('[data-depends-on^="variant:"]').forEach(function(el){ var v = el.getAttribute('data-depends-on').split(':')[1]; if(v.charAt(0)==='!') { el.style.display = (this.value !== v.slice(1)) ? '' : 'none'; } else { el.style.display = (v === this.value) ? '' : 'none'; } }.bind(this));`;
								} else if (
									[
										'playground-input',
										'playground-select',
										'playground-textarea',
										'playground-checkbox',
										'playground-radio',
										'playground-switch',
									].includes(config.elementId) &&
									prop.name === 'validation'
								) {
									const fieldId =
										config.elementId === 'playground-input'
											? 'playground-input-field'
											: config.elementId === 'playground-select'
												? 'playground-select-field'
												: config.elementId === 'playground-checkbox'
													? 'playground-checkbox-input'
													: config.elementId === 'playground-radio'
														? 'playground-radio-input'
														: config.elementId === 'playground-switch'
															? 'playground-switch-input'
															: 'playground-textarea-field';
									const validInfoId =
										config.elementId === 'playground-input'
											? 'playground-input-infotext-valid'
											: config.elementId === 'playground-select'
												? 'playground-select-infotext-valid'
												: config.elementId === 'playground-checkbox'
													? 'playground-checkbox-infotext-valid'
													: config.elementId === 'playground-switch'
														? 'playground-switch-infotext-valid'
														: 'playground-textarea-infotext-valid';
									const invalidInfoId =
										config.elementId === 'playground-input'
											? 'playground-input-infotext'
											: config.elementId === 'playground-select'
												? 'playground-select-infotext'
												: config.elementId === 'playground-checkbox'
													? 'playground-checkbox-infotext'
													: config.elementId === 'playground-switch'
														? 'playground-switch-infotext'
														: 'playground-textarea-infotext';
									{
									const messageId =
										config.elementId === 'playground-input'
											? 'playground-input-message'
											: config.elementId === 'playground-select'
												? 'playground-select-message'
												: config.elementId === 'playground-checkbox'
													? 'playground-checkbox-message'
													: config.elementId === 'playground-switch'
														? 'playground-switch-message'
														: config.elementId === 'playground-textarea'
															? 'playground-textarea-message'
														: null;
									const msgHide = messageId
										? `var msg = document.getElementById('${messageId}'); if(msg) msg.style.display = 'none';`
										: '';
									const msgRestore = messageId
										? `var msg = document.getElementById('${messageId}'); if(msg) { var smCb = this.closest('.controls-area-content').querySelector('input[type=checkbox][onchange*="${messageId}"]'); if(smCb && smCb.checked) msg.style.display = ''; }`
										: '';
