---
import { DBCard } from '@db-ux/react-core-components';
import DisabledWrapper from '@template/components/DisabledWrapper/DisabledWrapper.astro';
import TextImage from '@template/components/TextImage/TextImage.astro';
import './TeaserCard.css';

/**
 * TeaserCard – A flexible card grid for linking to related pages or resources.
 *
 * ## Component Props
 *
 * | Prop           | Type                                  | Default   | Description                                                        |
 * |----------------|---------------------------------------|-----------|--------------------------------------------------------------------|
 * | `teasers`      | `Teaser[]`                            | required  | Array of teaser items to render as cards                           |
 * | `columns`      | `number`                              | auto-fit  | Fixed column count (1–4). Uses responsive auto-fit when omitted    |
 * | `spacing`      | `'none' \| 'small' \| 'medium' \| 'large'` | `'small'` | Card padding passed to DBCard                                 |
 * | `headlineSize` | `'small' \| 'medium' \| 'large'`      | `'small'` | Headline font size (3xs / 2xs / sm)                                |
 *
 * ## Teaser Item Props
 *
 * | Prop            | Type                                              | Default     | Description                                          |
 * |-----------------|---------------------------------------------------|-------------|------------------------------------------------------|
 * | `title`         | `string`                                          | required    | Card headline                                        |
 * | `description`   | `string`                                          | required    | Card body text                                       |
 * | `url`           | `string`                                          | –           | Link target. Card is non-interactive without it      |
 * | `external`      | `boolean`                                         | `false`     | Opens in new tab, adds visually hidden a11y hint     |
 * | `disabled`      | `boolean`                                         | `false`     | Shows "Coming Soon" overlay, disables interaction    |
 * | `imageSrc`      | `string`                                          | –           | Image URL (light mode). Enables image teaser variant |
 * | `imageSrcDark`  | `string`                                          | –           | Image URL (dark mode). Falls back to imageSrc        |
 * | `imageAlt`      | `string`                                          | `title`     | Alt text for the image                               |
 * | `imagePosition` | `'top' \| 'bottom' \| 'left' \| 'right'`         | `'top'`     | Image placement relative to text                     |
 * | `imageWidth`    | `'50' \| '33' \| '66'`                            | –           | Image/text ratio for horizontal layouts              |
 * | `mask`          | `'fade-right' \| 'fade-left' \| ... \| 'fade-top-left'` | –    | CSS mask gradient applied to the image               |
 */

interface Props {
	teasers: {
		title: string;
		description: string;
		url?: string;
		/** Opens link in a new tab (adds target="_blank" and noreferrer) */
		external?: boolean;
		disabled?: boolean;
		imageSrc?: string;
		imageSrcDark?: string;
		imageAlt?: string;
		imagePosition?: 'top' | 'bottom' | 'left' | 'right';
		imageWidth?: '50' | '33' | '66';
		mask?:
			| 'fade-right'
			| 'fade-left'
			| 'fade-top'
			| 'fade-bottom'
			| 'fade-bottom-right'
			| 'fade-bottom-left'
			| 'fade-top-right'
			| 'fade-top-left';
	}[];
	/** Fixed number of columns (e.g. 2 or 3). Uses auto-fit when omitted. */
	columns?: number;
	/** Card spacing passed to DBCard. Defaults to 'small'. */
	spacing?: 'none' | 'small' | 'medium' | 'large';
	/** Headline size inside cards. Defaults to 'small' (headline-3xs). */
	headlineSize?: 'small' | 'medium' | 'large';
}

const { teasers, columns, spacing = 'small', headlineSize = 'small' } = Astro.props;
---

<div class={`teaser-cards${columns ? ` teaser-cards-cols-${columns}` : ''}${headlineSize === 'large' ? ' teaser-cards-large' : headlineSize === 'medium' ? ' teaser-cards-medium' : ''}`}>
	{
		teasers.map((teaser) => {
			const hasImage = !!teaser.imageSrc;
			const isDisabled = teaser.disabled === true;

			const cardContent = hasImage ? (
				<TextImage
					title={teaser.title}
					imagePosition={teaser.imagePosition ?? 'top'}
					imageWidth={teaser.imageWidth}
					imageSrc={teaser.imageSrc!}
					imageSrcDark={teaser.imageSrcDark}
					imageAlt={teaser.imageAlt ?? teaser.title}
					mask={teaser.mask}
					headlineLevel={3}
				>
					{teaser.description}
				</TextImage>
			) : (
				<div class="teaser-content">
					<h3 class="teaser-title">{teaser.title}</h3>
					<p class="teaser-description">{teaser.description}</p>
				</div>
			);

			return isDisabled ? (
				<DisabledWrapper label="Coming Soon" size={hasImage ? 'medium' : 'small'}>
					<DBCard spacing={spacing}>{cardContent}</DBCard>
				</DisabledWrapper>
			) : teaser.url ? (
				<a
					href={teaser.url}
					class="teaser-card-link"
					{...(teaser.external
						? { target: '_blank', rel: 'noreferrer' }
						: {})}
				>
					<DBCard behavior="interactive" spacing={spacing}>
						{cardContent}
					</DBCard>
					{teaser.external && (
						<span data-visually-hidden="true">(opens in new tab)</span>
					)}
				</a>
			) : (
				<DBCard spacing={spacing}>{cardContent}</DBCard>
			);
		})
	}
</div>
