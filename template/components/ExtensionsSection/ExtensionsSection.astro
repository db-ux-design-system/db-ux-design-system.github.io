---
import { appConfig } from '@config';
import { DBSection } from '@db-ux/react-core-components';
import TeaserCard from '@template/components/TeaserCard/TeaserCard.astro';

interface Props {
	riText?: string;
	dataVizText?: string;
	tableText?: string;
	contentText?: string;
	ariaLabel?: string;
	width?: 'small' | 'medium' | 'large' | 'full';
	/** When true, omits the wrapping DBSection (use when already inside a layout section) */
	noSection?: boolean;
}

const {
	riText = 'Deliver reliable traveler information.',
	dataVizText = 'Enable clear visualization of complex data.',
	tableText = 'Display large datasets in a consistent format.',
	contentText = 'Support consistent communication across channels.',
	ariaLabel = 'Extensions section',
	width = 'medium',
	noSection = false,
} = Astro.props;

const teasers = [
	{
		title: 'RI Extension',
		description: riText,
		url: 'https://marketingportal.extranet.deutschebahn.com/marketingportal/Design-Anwendungen/User-Experience/DB-UX-Design-System/extensions/reisendeninformation',
		external: true,
		imageSrc: `${appConfig.basePath}assets/extensions/RI--Lightmode--C.png`,
		imageSrcDark: `${appConfig.basePath}assets/extensions/RI--Darkmode--C.png`,
		imageAlt: 'RI Extension Visual',
		imagePosition: 'bottom' as const,
		mask: 'fade-bottom-right' as const,
	},
	{
		title: 'DataViz Extension',
		description: dataVizText,
		url: 'https://marketingportal.extranet.deutschebahn.com/marketingportal/Design-Anwendungen/User-Experience/DB-UX-Design-System/extensions/dataviz',
		external: true,
		imageSrc: `${appConfig.basePath}assets/extensions/DataViz--Lightmode--C.png`,
		imageSrcDark: `${appConfig.basePath}assets/extensions/DataViz--Darkmode--C.png`,
		imageAlt: 'DataViz Extension Visual',
		imagePosition: 'bottom' as const,
		mask: 'fade-bottom-right' as const,
	},
	{
		title: 'Table Extension',
		description: tableText,
		url: 'https://marketingportal.extranet.deutschebahn.com/marketingportal/Design-Anwendungen/User-Experience/DB-UX-Design-System/extensions/table',
		external: true,
		imageSrc: `${appConfig.basePath}assets/extensions/Table--Lightmode--C.png`,
		imageSrcDark: `${appConfig.basePath}assets/extensions/Table--Darkmode--C.png`,
		imageAlt: 'Table Extension Visual',
		imagePosition: 'bottom' as const,
		mask: 'fade-bottom-right' as const,
	},
	{
		title: 'Content Extension',
		description: contentText,
		disabled: true,
		imageSrc: `${appConfig.basePath}assets/extensions/Content--Lightmode--C.png`,
		imageSrcDark: `${appConfig.basePath}assets/extensions/Content--Darkmode--C.png`,
		imageAlt: 'Content Extension Visual',
		imagePosition: 'bottom' as const,
		mask: 'fade-bottom-right' as const,
	},
];
---

{
	noSection ? (
		<section aria-label={ariaLabel} id="extensions--extensions-section">
			<TeaserCard teasers={teasers} columns={2} spacing="large" headlineSize="large" headlineLevel={2} />
		</section>
	) : (
		<DBSection
			width={width}
			spacing="medium"
			aria-label={ariaLabel}
			id="extensions--extensions-section"
		>
			<TeaserCard teasers={teasers} columns={2} spacing="large" headlineSize="large" headlineLevel={2} />
		</DBSection>
	)
}
