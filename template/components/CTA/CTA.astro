---
import './CTA.css';
import { DBCard } from '@db-ux/react-core-components';

type ButtonVariant = 'brand' | 'outlined' | 'filled' | 'ghost';

interface Action {
	label: string;
	href: string;
	variant?: ButtonVariant;
}

interface Props {
	title?: string;
	text?: string;
	primaryAction: Action;
	secondaryAction?: Action;
	align?: 'center' | 'start' | 'end';
}

const { title, text, primaryAction, secondaryAction, align = 'center' } = Astro.props as Props;

const BUTTON_VARIANTS: ButtonVariant[] = ['outlined', 'brand', 'filled', 'ghost'];

const normalizeVariant = (
	variant: ButtonVariant | undefined,
	fallback: ButtonVariant,
): ButtonVariant =>
	BUTTON_VARIANTS.includes(variant as ButtonVariant) ? (variant as ButtonVariant) : fallback;
---

{
	primaryAction && (
		<DBCard spacing="large" elevationLevel="2" className="cta">
			<div class="cta-content" data-align={align}>
				{title && <h3 class="cta-title">{title}</h3>}
				{text && <p class="cta-text">{text}</p>}
				<div class="cta-actions">
					<a
						href={primaryAction.href}
						class="db-button"
						data-variant={normalizeVariant(primaryAction.variant, 'brand')}
					>
						{primaryAction.label}
					</a>
					{secondaryAction && (
						<a
							href={secondaryAction.href}
							class="db-button"
							data-variant={normalizeVariant(secondaryAction.variant, 'outlined')}
						>
							{secondaryAction.label}
						</a>
					)}
				</div>
			</div>
		</DBCard>
	)
}
