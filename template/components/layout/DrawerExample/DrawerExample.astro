---
import DrawerExampleReact from './DrawerExample.tsx';

type DrawerDirection = 'left' | 'right' | 'up' | 'down' | 'custom';
type DrawerBackdrop = 'none' | 'strong' | 'weak' | 'invisible';

interface Props {
	direction?: DrawerDirection;
	backdrop?: DrawerBackdrop;
}

const { direction = 'right', backdrop = 'strong' } = Astro.props;
---

<DrawerExampleReact direction={direction} backdrop={backdrop} client:load />
