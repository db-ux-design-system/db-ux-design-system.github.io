---
import { DBBadge, DBCard } from '@db-ux/react-core-components';
import { readFileSync, existsSync } from 'fs';
import { resolve } from 'path';
import './GuidelineExample.css';

interface Props {
	variant?: 'do' | 'dont' | 'caution';
	figmaUrl: string;
	description?: string;
	fullWidth?: boolean;
	layout?: 'default' | 'side';
}

const { variant, figmaUrl, description, fullWidth = false, layout = 'default' } = Astro.props;
const semantic =
	variant === 'do'
		? 'successful'
		: variant === 'caution'
			? 'warning'
			: variant === 'dont'
				? 'critical'
				: undefined;
const label =
	variant === 'do'
		? 'Do'
		: variant === 'caution'
			? 'Caution'
			: variant === 'dont'
				? "Don't"
				: undefined;
const fullUrl = `${figmaUrl}&embed-host=share&footer=false&viewport-controls=false&page-selector=false&scaling=scale-down-width`;

// Resolve cached image from manifest
const manifestPath = resolve('static/assets/figma-cache/manifest.json');
let cachedImageSrc: string | undefined;
if (existsSync(manifestPath)) {
	const manifest = JSON.parse(readFileSync(manifestPath, 'utf-8'));
	// Normalize lookup key: strip extra embed params, keep node-id only
	const base = figmaUrl.split('?')[0];
	const nodeIdMatch = figmaUrl.match(/[?&]node-id=([^&]+)/);
	const lookupKey = nodeIdMatch ? `${base}?node-id=${nodeIdMatch[1]}&embed-host=share` : figmaUrl;
	cachedImageSrc = manifest[lookupKey];
}

const hasSlot = Astro.slots.has('default');
---

<figure class="guideline-example-container" data-full-width={fullWidth} data-layout={layout}>
	<DBCard elevationLevel="2" data-mode="light">
		{
			variant && (
				<div class="guideline-example-badge">
					<DBBadge semantic={semantic} emphasis="strong" size="medium">
						<span>{label}</span>
					</DBBadge>
				</div>
			)
		}
		{
			cachedImageSrc ? (
				<img
					class="guideline-example-iframe"
					src={cachedImageSrc}
					alt=""
					loading="lazy"
				/>
			) : (
				<iframe
					class="guideline-example-iframe"
					src={fullUrl}
					title={description ?? ''}
					loading="eager"
					allowfullscreen
				/>
			)
		}
	</DBCard>
	{layout === 'side' && hasSlot ? (
		<figcaption class="guideline-example-side-content">
			<slot />
		</figcaption>
	) : description ? (
		<figcaption>{description}</figcaption>
	) : null}
</figure>
