---
import './QuestionForm.css';

interface Props {
	componentName?: string;
}

const { componentName } = Astro.props;

const subject = componentName
	? `Question: ${componentName} component`
	: 'Question about DB UX Design System';

const encodedSubject = encodeURIComponent(subject);
const mailTo = 'db-ux-designsystem@deutschebahn.com';
---

<section class="question-form" aria-label="Question contact">
	<div class="db-textarea" data-variant="above">
		<label for={`question-form-${componentName?.replace(/\s+/g, '-').toLowerCase() ?? 'general'}`}>
			Your question
		</label>
		<textarea
			id={`question-form-${componentName?.replace(/\s+/g, '-').toLowerCase() ?? 'general'}`}
			rows="4"
			placeholder="Type your question here…"></textarea>
	</div>
	<button
		class="db-button"
		data-variant="brand"
		type="button"
		onclick={`
			const textarea = this.previousElementSibling.querySelector('textarea');
			const body = encodeURIComponent(textarea.value);
			window.location.href = 'mailto:${mailTo}?subject=${encodedSubject}&body=' + body;
		`}
	>
		Email the DB UX team
	</button>
</section>
