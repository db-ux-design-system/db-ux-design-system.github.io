---
import './QuestionForm.css';

interface Props {
	componentName?: string;
}

const { componentName } = Astro.props;

const isDE = Astro.url.pathname.startsWith('/de/') || Astro.url.pathname === '/de';

const subject = componentName ? `Question: ${componentName}` : 'Question about DB UX Design System';

const encodedSubject = encodeURIComponent(subject);
const mailTo = 'db-ux-designsystem@deutschebahn.com';
const fieldId = `question-form-${(componentName ?? 'general')
	.toLowerCase()
	.replace(/[^a-z0-9]+/g, '-')
	.replace(/^-|-$/g, '')}`;

const introText = isDE
	? `Du hast eine Frage zu ${componentName}? Wir beantworten sie und ergänzen häufig gestellte Fragen auf dieser Seite.`
	: `Have a question about ${componentName}? We'll answer it and add frequently asked questions to this page.`;
const labelText = isDE ? 'Deine Frage' : 'Your question';
const placeholderText = isDE ? 'Frage hier eingeben…' : 'Type your question here…';
const buttonText = isDE ? 'Dem DB UX Team schreiben' : 'Email the DB UX team';
const fallbackText = isDE ? 'Oder direkt an' : 'Or write directly to';
---

<section class="question-form" aria-label={isDE ? 'Fragen-Kontakt' : 'Question contact'}>
	<p>{introText}</p>
	<div class="db-textarea" data-variant="above">
		<label for={fieldId}>{labelText}</label>
		<textarea id={fieldId} rows="4" placeholder={placeholderText}></textarea>
	</div>
	<button
		class="db-button"
		data-variant="brand"
		type="button"
		onclick={`
			const textarea = document.getElementById('${fieldId}');
			const body = encodeURIComponent(textarea.value);
			window.location.href = 'mailto:${mailTo}?subject=${encodedSubject}&body=' + body;
		`}
	>{buttonText}</button>
	<p class="question-form-fallback">
		{fallbackText} <a href={`mailto:${mailTo}`}>{mailTo}</a>
	</p>
</section>
