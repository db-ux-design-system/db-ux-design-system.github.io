---
import './QuestionForm.css';

interface Props {
	componentName?: string;
}

const { componentName } = Astro.props;

const subject = componentName
	? `Question: ${componentName} component`
	: 'Question about DB UX Design System';

const mailtoHref = `mailto:db-ux-designsystem@deutschebahn.com?subject=${encodeURIComponent(subject)}`;
---

<section class="question-form" aria-label="Question contact">
	<p class="question-form-text">Send us your question directly with your preferred email client.</p>
	<a class="db-link" data-variant="brand" href={mailtoHref}>Email the DB UX team</a>
</section>
