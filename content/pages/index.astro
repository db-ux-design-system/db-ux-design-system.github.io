---
import { DBSection } from '@db-ux/react-core-components';
import PageHero from '@template/components/content/PageHero/PageHero.astro';
import InteractiveDemoSection from '@components/content/InteractiveDemoSection/InteractiveDemoSection.astro';
import PackagesSection from '@components/content/PackagesSection/PackagesSection.astro';
import DesignedForSection from '@components/content/DesignedForSection/DesignedForSection.astro';
import TestimonialsSection from '@components/content/TestimonialsSection/TestimonialsSection.astro';
import SharedStandardsSection from '@components/content/SharedStandardsSection/SharedStandardsSection.astro';
import DefaultLayout from '@template/layouts/default';
---

<DefaultLayout frontmatter={{}}>
	<DBSection width="medium" spacing="medium" id="home--page-hero-section">
		<PageHero
			title="DB UX Design System"
			headlineLevel={1}
			headline="A Design System designed to align teams and streamline product delivery."
			description="Brings clarity to design and implementation through shared standards and reusable components."
		/>
	</DBSection>

	<InteractiveDemoSection />

	<PackagesSection />

	<DesignedForSection />

	<TestimonialsSection />

	<SharedStandardsSection />
</DefaultLayout>

<script>
	import { waitForElements } from '@template/utils/client.utils.ts';

	function initDemo(): boolean {
		const iframe = document.querySelector<HTMLIFrameElement>('[id="demo-iframe"]');
		const toggle = document.getElementById('toggle-demo');
		const toggleMode = document.getElementById('toggle-mode');
		const fullscreenAnchor: HTMLAnchorElement | null = document.querySelector<HTMLAnchorElement>(
			'[id="fullscreen-anchor"]',
		);

		if (!iframe || !toggle || !toggleMode || !fullscreenAnchor) return false;

		let currentDemo = 'b2b';
		let currentMode = 'light';

		fullscreenAnchor.href = iframe.src;

		toggle.addEventListener('click', () => {
			currentDemo = currentDemo === 'b2b' ? 'b2c' : 'b2b';
			const href = `/demo-${currentDemo}`;
			iframe.src = href;
			fullscreenAnchor.href = href;
			toggle.textContent = currentDemo === 'b2b' ? 'Show B2C Example' : 'Show B2B Example';
		});

		toggleMode.addEventListener('click', () => {
			currentMode = currentMode === 'light' ? 'dark' : 'light';
			iframe.src = `/demo-${currentDemo}?mode=${currentMode}`;
			toggleMode.setAttribute('data-icon', currentMode === 'light' ? 'moon' : 'sun');
			toggleMode.setAttribute(
				'title',
				currentMode === 'light' ? 'Toggle dark mode' : 'Toggle light mode',
			);
			const tooltip = toggleMode.querySelector('.db-tooltip');
			if (tooltip)
				tooltip.textContent = currentMode === 'light' ? 'Toggle dark mode' : 'Toggle light mode';
		});

		document.addEventListener('click', (e) => {
			const target = (e.target as HTMLElement)?.closest<HTMLElement>('[data-action]');
			if (!target) return;

			const action = target.dataset.action;
			const value = target.dataset.value;
			if (action && value) {
				iframe.src = `/demo-${currentDemo}?${action}=${value}`;
			}
		});

		return true;
	}

	waitForElements(initDemo);
</script>
