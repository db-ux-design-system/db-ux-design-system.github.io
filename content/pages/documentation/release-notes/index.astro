---
import DocumentationLayout from '@template/layouts/documentation';
import { DBTag, DBStack, DBCheckbox, DBDivider } from '@db-ux/react-core-components';
import './index.css';
import type { MarkdownInstance } from 'astro';
type ReleaseNote = {
	slug: string;
	heading: string;
	category: string;
	version: string;
	date: Date;
	Content: MarkdownInstance<any>['Content'];
};

export const frontmatter = {
	order: 1,
	layout: '@template/layouts/documentation',
	headline: 'Release Notes',
	title: 'Release Notes',
	description:
		'Stay up to date with the latest changes, improvements, fixes, and new features across the design system.',
	align: 'start' as const,
	toc: true,
};
const releaseNoteFiles = import.meta.glob<MarkdownInstance<any>>('./_content/*.md', {
	eager: true,
});
const releaseNotes: ReleaseNote[] = Object.values(releaseNoteFiles)
	.map(({ frontmatter, Content }) => {
		const heading = `${frontmatter.category} – ${frontmatter.version}`;
		const slug = heading
			.normalize('NFD')
			.replace(/[\u0300-\u036f]/g, '')
			.toLowerCase()
			.replace(/[^a-z0-9]+/g, '-')
			.replace(/^-|-$/g, '');
		return {
			slug,
			heading,
			category: frontmatter.category,
			date: new Date(frontmatter.date),
			Content,
			version: frontmatter.version,
		} as ReleaseNote;
	})
	.sort((a: ReleaseNote, b: ReleaseNote) => b.date.getTime() - a.date.getTime());

const categories = [...new Set(releaseNotes.map((note) => note.category))];
---

<DocumentationLayout
	frontmatter={frontmatter}
	headings={releaseNotes.map(({ heading, slug }) => ({ text: heading, depth: 2, slug }))}
>
	<DBStack>
		<DBStack id="filter-tags" direction="row" alignment="center" wrap="true" role="group">
			<small>Filter:</small>
			{
				categories.map((cat) => (
					<DBTag data-category={cat} client:load showCheckState={false}>
						<DBCheckbox>{cat}</DBCheckbox>
					</DBTag>
				))
			}
		</DBStack>
		{
			releaseNotes.map((note) => (
				<article class="release-note" data-category={note.category}>
					<DBStack direction="row" justifyContent="space-between" alignment="center">
						<h2 id={note.slug} class="release-note-version">
							{note.heading}
						</h2>
						<time class="release-note-date">{note.date.toLocaleDateString()}</time>
					</DBStack>

					<note.Content />
					<DBDivider />
				</article>
			))
		}
	</DBStack>
</DocumentationLayout>

<script is:inline slot="script">
	document.addEventListener(
		'change',
		function (event) {
			const checkbox = event.target;
			if (!checkbox || checkbox.type !== 'checkbox') return;

			const filterContainer = document.getElementById('filter-tags');
			if (!filterContainer || !filterContainer.contains(checkbox)) return;

			const filterTags = filterContainer.querySelectorAll('[data-category]');
			const releaseNotes = document.querySelectorAll('.release-note');
			const tocHeadingNotes = document.querySelectorAll('.dba-toc-heading');

			const activeCategories = [];
			filterTags.forEach(function (tag) {
				var cb = tag.querySelector('input[type="checkbox"]');
				if (cb && cb.checked) {
					activeCategories.push(tag.getAttribute('data-category'));
				}
			});

			releaseNotes.forEach(function (note) {
				var noteCategory = note.getAttribute('data-category');
				note.hidden = !(activeCategories.length === 0 || activeCategories.includes(noteCategory));
			});

			tocHeadingNotes.forEach(function (heading) {
				heading.style.display =
					activeCategories.length === 0 ||
					activeCategories.some(function (category) {
						return heading.textContent.startsWith(category);
					})
						? 'flex'
						: 'none';
			});
		},
		true,
	);
</script>
