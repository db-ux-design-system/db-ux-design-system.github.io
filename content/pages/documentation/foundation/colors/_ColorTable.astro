	'on-bg-basic-emphasis-90-pressed',
	'on-bg-basic-emphasis-80-default',
	'on-bg-basic-emphasis-80-hovered',
	'on-bg-basic-emphasis-80-pressed',
	'on-bg-basic-emphasis-70-default',
	'on-bg-basic-emphasis-70-hovered',
	'on-bg-basic-emphasis-70-pressed',
	'on-bg-basic-emphasis-60-default',
	'on-bg-basic-emphasis-50-default',
	'bg-inverted-contrast-max-default',
