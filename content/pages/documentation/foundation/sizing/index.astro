---
import DocumentationLayout from '@template/layouts/documentation/DocumentationLayout.astro';
import { DBSection, DBStack } from '@db-ux/react-core-components';
import SizingPlayground from '@template/components/documentation/SizingPlayground/SizingPlayground.astro';
import SizingTable from '@template/components/documentation/SizingTable/SizingTable.astro';
import QuestionForm from '@template/components/feedback/QuestionForm/QuestionForm.astro';

const frontmatter: DocumentationFrontMatter = {
	headline: 'Sizing',
	title: 'Sizing',
	align: 'start',
	toc: true,
	sectionSpacing: 'small',
	sectionWidth: 'auto',
};

const headings = [
	{ depth: 2, slug: 'playground', text: 'Playground' },
	{ depth: 2, slug: 'tokens', text: 'Tokens' },
	{ depth: 2, slug: 'faq', text: 'FAQ' },
];
---

<DocumentationLayout frontmatter={frontmatter} headings={headings}>
	Sizing refers to the consistent use of set sizes for elements and components, regardless of device
	screen. Fixed sizings ensure that layouts remain balanced and components are easily recognizable
	across desktop, tablet, and mobile devices.

	<DBSection id="sizing--playground" spacing="small" width="large">
		<DBStack gap="x-large">
			<DBStack gap="none">
				<h2 id="playground">Playground</h2>
				<br />
				Experiment with sizing tokens to see how they scale across different densities.
			</DBStack>
			<SizingPlayground layout="horizontal" />
		</DBStack>
	</DBSection>

	<DBSection id="sizing--tokens" spacing="small" width="large">
		<h2 id="tokens">Tokens</h2>
		<SizingTable />
	</DBSection>

	<DBSection id="sizing--faq" spacing="small" width="large">
		<h2 id="faq">FAQ</h2>
		<QuestionForm componentName="Sizing" />
	</DBSection>

	<script>
		import { waitForElements } from '@template/utils/client.utils.ts';
		import { handleSimplePlaygrounds } from '@template/components/documentation/FoundationPlayground';

		function initSizing(): boolean {
			return handleSimplePlaygrounds({
				dataAttributeName: 'size',
				tokenPrefix: 'sizing',
				popoverLabel: 'Size',
				remPx: true,
				withDensity: true,
			});
		}

		waitForElements(initSizing);
	</script>
</DocumentationLayout>
