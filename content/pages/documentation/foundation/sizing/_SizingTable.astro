---
import TokenTable from '../_shared/TokenTable.astro';

const sizingTokens = [
	{ token: 'db-sizing-3xs', functional: '0.375rem (6px)', regular: '0.5rem (8px)', expressive: '0.625rem (10px)' },
	{ token: 'db-sizing-2xs', functional: '0.625rem (10px)', regular: '0.75rem (12px)', expressive: '0.875rem (14px)' },
	{ token: 'db-sizing-xs', functional: '0.875rem (14px)', regular: '1rem (16px)', expressive: '1.25rem (20px)' },
	{ token: 'db-sizing-sm', functional: '1.25rem (20px)', regular: '1.5rem (24px)', expressive: '1.75rem (28px)' },
	{ token: 'db-sizing-md', functional: '2rem (32px)', regular: '2.5rem (40px)', expressive: '3rem (48px)' },
	{ token: 'db-sizing-lg', functional: '3rem (48px)', regular: '4rem (64px)', expressive: '5rem (80px)' },
	{ token: 'db-sizing-xl', functional: '5rem (80px)', regular: '6rem (96px)', expressive: '7.5rem (120px)' },
	{ token: 'db-sizing-2xl', functional: '7.5rem (120px)', regular: '10rem (160px)', expressive: '15rem (240px)' },
	{ token: 'db-sizing-3xl', functional: '10rem (160px)', regular: '15rem (240px)', expressive: '30rem (480px)' },
];

const containerTokens = [
	{ token: 'db-container-3xs', value: '14rem (224px)' },
	{ token: 'db-container-2xs', value: '16rem (256px)' },
	{ token: 'db-container-xs', value: '20rem (320px)' },
	{ token: 'db-container-sm', value: '24rem (384px)' },
	{ token: 'db-container-md', value: '28rem (448px)' },
	{ token: 'db-container-lg', value: '32rem (512px)' },
	{ token: 'db-container-xl', value: '36rem (576px)' },
	{ token: 'db-container-2xl', value: '42rem (672px)' },
	{ token: 'db-container-3xl', value: '48rem (768px)' },
];
---

<TokenTable
	sections={[
		{ headline: 'Component', variant: 'density', tokens: sizingTokens, showDensity: true },
		{ headline: 'Container', tokens: containerTokens },
	]}
/>
