---
import TokenTable from '../_shared/TokenTable.astro';

const fixedTokens = [
	{ token: 'db-spacing-fixed-3xs', functional: '0.125rem (2px)', regular: '0.125rem (2px)', expressive: '0.25rem (4px)' },
	{ token: 'db-spacing-fixed-2xs', functional: '0.25rem (4px)', regular: '0.25rem (4px)', expressive: '0.5rem (8px)' },
	{ token: 'db-spacing-fixed-xs', functional: '0.375rem (6px)', regular: '0.5rem (8px)', expressive: '0.75rem (12px)' },
	{ token: 'db-spacing-fixed-sm', functional: '0.5rem (8px)', regular: '0.75rem (12px)', expressive: '1rem (16px)' },
	{ token: 'db-spacing-fixed-md', functional: '0.75rem (12px)', regular: '1rem (16px)', expressive: '1.5rem (24px)' },
	{ token: 'db-spacing-fixed-lg', functional: '1rem (16px)', regular: '1.5rem (24px)', expressive: '2rem (32px)' },
	{ token: 'db-spacing-fixed-xl', functional: '1.5rem (24px)', regular: '2rem (32px)', expressive: '3rem (48px)' },
	{ token: 'db-spacing-fixed-2xl', functional: '2rem (32px)', regular: '3rem (48px)', expressive: '5rem (80px)' },
	{ token: 'db-spacing-fixed-3xl', functional: '3rem (48px)', regular: '5rem (80px)', expressive: '7.5rem (120px)' },
];

const responsiveTokens = [
	{
		token: 'db-spacing-responsive-3xs',
		functional: { desktop: '1rem (16px)', tablet: '1rem (16px)', mobile: '1rem (16px)' },
		regular: { desktop: '1.25rem (20px)', tablet: '1rem (16px)', mobile: '1rem (16px)' },
		expressive: { desktop: '1.75rem (28px)', tablet: '1.5rem (24px)', mobile: '1.25rem (20px)' },
	},
	{
		token: 'db-spacing-responsive-2xs',
		functional: { desktop: '1.25rem (20px)', tablet: '1.25rem (20px)', mobile: '1.25rem (20px)' },
		regular: { desktop: '1.5rem (24px)', tablet: '1.25rem (20px)', mobile: '1.25rem (20px)' },
		expressive: { desktop: '2rem (32px)', tablet: '1.75rem (28px)', mobile: '1.5rem (24px)' },
	},
	{
		token: 'db-spacing-responsive-xs',
		functional: { desktop: '1.75rem (28px)', tablet: '1.5rem (24px)', mobile: '1.25rem (20px)' },
		regular: { desktop: '2rem (32px)', tablet: '1.75rem (28px)', mobile: '1.5rem (24px)' },
		expressive: { desktop: '3rem (48px)', tablet: '2.5rem (40px)', mobile: '2rem (32px)' },
	},
	{
		token: 'db-spacing-responsive-sm',
		functional: { desktop: '2.5rem (40px)', tablet: '2rem (32px)', mobile: '1.75rem (28px)' },
		regular: { desktop: '3rem (48px)', tablet: '2.5rem (40px)', mobile: '2rem (32px)' },
		expressive: { desktop: '5rem (80px)', tablet: '4rem (64px)', mobile: '3rem (48px)' },
	},
	{
		token: 'db-spacing-responsive-md',
		functional: { desktop: '4rem (64px)', tablet: '3rem (48px)', mobile: '2.5rem (40px)' },
		regular: { desktop: '5rem (80px)', tablet: '4rem (64px)', mobile: '3rem (48px)' },
		expressive: { desktop: '7.5rem (120px)', tablet: '6rem (96px)', mobile: '5rem (80px)' },
	},
	{
		token: 'db-spacing-responsive-lg',
		functional: { desktop: '6rem (96px)', tablet: '5rem (80px)', mobile: '4rem (64px)' },
		regular: { desktop: '7.5rem (120px)', tablet: '6rem (96px)', mobile: '5rem (80px)' },
		expressive: { desktop: '15rem (240px)', tablet: '10rem (160px)', mobile: '7.5rem (120px)' },
	},
	{
		token: 'db-spacing-responsive-xl',
		functional: { desktop: '10rem (160px)', tablet: '7.5rem (120px)', mobile: '6rem (96px)' },
		regular: { desktop: '15rem (240px)', tablet: '10rem (160px)', mobile: '7.5rem (120px)' },
		expressive: { desktop: '30rem (480px)', tablet: '15rem (240px)', mobile: '10rem (160px)' },
	},
	{
		token: 'db-spacing-responsive-2xl',
		functional: { desktop: '15rem (240px)', tablet: '10rem (160px)', mobile: '7.5rem (120px)' },
		regular: { desktop: '30rem (480px)', tablet: '15rem (240px)', mobile: '10rem (160px)' },
		expressive: { desktop: '40rem (640px)', tablet: '30rem (480px)', mobile: '15rem (240px)' },
	},
	{
		token: 'db-spacing-responsive-3xl',
		functional: { desktop: '30rem (480px)', tablet: '15rem (240px)', mobile: '10rem (160px)' },
		regular: { desktop: '40rem (640px)', tablet: '30rem (480px)', mobile: '15rem (240px)' },
		expressive: { desktop: '50rem (800px)', tablet: '40rem (640px)', mobile: '30rem (480px)' },
	},
];
---

<TokenTable
	sections={[
		{ headline: 'Fixed', variant: 'density', tokens: fixedTokens, showDensity: true },
		{ headline: 'Responsive', variant: 'responsive', tokens: responsiveTokens },
	]}
/>
