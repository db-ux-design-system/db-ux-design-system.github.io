---
import DocumentationLayout from '@template/layouts/documentation/DocumentationLayout.astro';
import { DBSection, DBStack } from '@db-ux/react-core-components';
import SpacingPlayground from '@template/components/documentation/SpacingPlayground/SpacingPlayground.astro';
import SpacingTable from '@template/components/documentation/SpacingTable/SpacingTable.astro';
import GuidelineExample from '@template/components/documentation/GuidelineExample/GuidelineExample.astro';
import CollapseButton from '@template/components/navigation/CollapseButton/CollapseButton.astro';
import CollapsibleWrapper from '@template/components/navigation/CollapseButton/CollapsibleWrapper.astro';
import QuestionForm from '@template/components/feedback/QuestionForm/QuestionForm.astro';

const frontmatter: DocumentationFrontMatter = {
	headline: 'Spacing',
	title: 'Spacing',
	align: 'start',
	toc: true,
	sectionSpacing: 'small',
	sectionWidth: 'auto',
};

const headings = [
	{ depth: 2, slug: 'playground', text: 'Playground' },
	{ depth: 2, slug: 'guidelines', text: 'Guidelines' },
	{ depth: 2, slug: 'tokens', text: 'Tokens' },
	{ depth: 2, slug: 'faq', text: 'FAQ' },
];
---

<DocumentationLayout frontmatter={frontmatter} headings={headings}>
	Spacing is a key element of our design system and defines the gaps between different components.
	Consistent use of spacing ensures a harmonious, clear, and user-friendly appearance.

	<DBSection id="spacing--playground" spacing="small" width="large">
		<DBStack gap="x-large">
			<DBStack gap="none">
				<h2 id="playground">Playground</h2>
				<br />
				Experiment with spacing tokens to see how gap and padding affect layout.
			</DBStack>
			<SpacingPlayground layout="horizontal" />
		</DBStack>
	</DBSection>

	<DBSection id="spacing--guidelines" spacing="small" width="large">
		<h2 id="guidelines">Guidelines</h2>

		<CollapsibleWrapper collapsedHeight="320px">
			<h3>Fixed Spacing</h3>

			<p>
				Fixed spacings are gaps that remain the same regardless of screen size. They are typically
				used within components and modules to ensure a uniform and clear structure across different
				devices.
			</p>

			<div class="guideline-examples">
				<GuidelineExample
					figmaUrl="https://embed.figma.com/design/Ji70muzdgUXAcN0Qs8eSY2/Doku--Spacing?node-id=1-1132&embed-host=share"
					fullWidth={true}
					description="Fixed Spacing"
				/>
			</div>

			<h3>Responsive Spacing</h3>

			<p>
				Responsive spacings are gaps that automatically adapt to the size of the device screen
				(desktop, tablet, mobile). They are ideal for separating different layout areas and ensure a
				consistent, user-friendly appearance across all devices.
			</p>

			<div class="guideline-examples">
				<GuidelineExample
					figmaUrl="https://embed.figma.com/design/Ji70muzdgUXAcN0Qs8eSY2/Doku--Spacing?node-id=1-1133&embed-host=share"
					fullWidth={true}
					description="Responsive Spacing"
				/>
			</div>
		</CollapsibleWrapper>

		<CollapseButton collapsedText="Show all Guidelines" expandedText="Hide some Guidelines" />
	</DBSection>

	<DBSection id="spacing--tokens" spacing="small" width="large">
		<h2 id="tokens">Tokens</h2>
		<SpacingTable />
	</DBSection>

	<DBSection id="spacing--faq" spacing="small" width="large">
		<h2 id="faq">FAQ</h2>
		<QuestionForm componentName="Spacing" />
	</DBSection>

	<script>
		import { waitForElements } from '@template/utils/client.utils.ts';
		import { handleSimplePlaygrounds } from '@template/components/documentation/FoundationPlayground';

		function initSpacing(): boolean {
			return handleSimplePlaygrounds({
				dataAttributeName: 'spacing',
				tokenPrefix: 'spacing-fixed',
				popoverLabel: 'Spacing',
				remPx: true,
				withDensity: true,
			});
		}

		waitForElements(initSpacing);
	</script>
</DocumentationLayout>
