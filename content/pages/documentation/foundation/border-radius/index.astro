---
import DocumentationLayout from '@template/layouts/documentation/DocumentationLayout.astro';
import { DBSection, DBStack } from '@db-ux/react-core-components';
import BorderRadiusPlayground from '@template/components/documentation/BorderRadiusPlayground/BorderRadiusPlayground.astro';
import BorderRadiusTable from '@template/components/documentation/BorderRadiusTable/BorderRadiusTable.astro';
import QuestionForm from '@template/components/feedback/QuestionForm/QuestionForm.astro';

const frontmatter: DocumentationFrontMatter = {
	headline: 'Border Radius',
	title: 'Border Radius',
	align: 'start',
	toc: true,
	sectionSpacing: 'small',
	sectionWidth: 'auto',
};

const headings = [
	{ depth: 2, slug: 'playground', text: 'Playground' },
	{ depth: 2, slug: 'tokens', text: 'Tokens' },
	{ depth: 2, slug: 'faq', text: 'FAQ' },
];
---

<DocumentationLayout frontmatter={frontmatter} headings={headings}>
	The border radius defines the rounded corners of UI elements, which influences the visual
	aesthetics of the design system. These tokens enable consistent corner properties for a harmonious
	user interface.

	<DBSection id="border-radius--playground" spacing="small" width="large">
		<DBStack gap="x-large">
			<DBStack gap="none">
				<h2 id="playground">Playground</h2>
				<br />
				Experiment with border radius tokens to see how they affect corner rounding.
			</DBStack>
			<BorderRadiusPlayground layout="horizontal" />
		</DBStack>
	</DBSection>

	<DBSection id="border-radius--tokens" spacing="small" width="large">
		<h2 id="tokens">Tokens</h2>
		<BorderRadiusTable />
	</DBSection>

	<DBSection id="border-radius--faq" spacing="small" width="large">
		<h2 id="faq">FAQ</h2>
		<QuestionForm componentName="Border Radius" />
	</DBSection>

	<script>
		import { waitForElements } from '@template/utils/client.utils.ts';
		import { handleSimplePlaygrounds } from '@template/components/documentation/FoundationPlayground';

		function initBorderRadius(): boolean {
			return handleSimplePlaygrounds({
				dataAttributeName: 'border-radius',
				tokenPrefix: 'border-radius',
				remPx: true,
				popoverLabel: 'Border Radius',
			});
		}

		waitForElements(initBorderRadius);
	</script>
</DocumentationLayout>
