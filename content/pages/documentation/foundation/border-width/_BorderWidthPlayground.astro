---
import { DBCard, DBPopover, type DBSelectOptionType } from '@db-ux/react-core-components';
import Playground from '../_shared/Playground.astro';
import './BorderWidthPlayground.css';

const widths: DBSelectOptionType[] = [
	{ value: '3xl', label: '3xl' },
	{ value: '2xl', label: '2xl' },
	{ value: 'xl', label: 'xl' },
	{ value: 'lg', label: 'lg' },
	{ value: 'md', label: 'md' },
	{ value: 'sm', label: 'sm' },
	{ value: 'xs', label: 'xs' },
	{ value: '2xs', label: '2xs' },
	{ value: '3xs', label: '3xs' },
];
---

<Playground
	selects={[{ id: 'select', label: 'Border Width', defaultValue: 'md', options: widths }]}
>
	<DBPopover width="fixed" gap="true">
		<button slot="trigger" id="box" class="width-box interactive-box" data-border-width="md">
			<DBCard behavior="interactive" spacing="none"> Focus Me </DBCard>
		</button>
	</DBPopover>
</Playground>
