---
import { DBSection } from '@db-ux/react-core-components';
import { CTA } from '@components';
---

<DBSection width="medium" spacing="medium" aria-label="CTA Bereich">
	<CTA
		title="Sprecht uns an"
		text="Wir sind da, wenn Fragen aufkommen oder Klarheit gebraucht wird. Meldet euch frühzeitig. Gemeinsamer Austausch stärkt die Qualität des Systems."
		primaryAction={{
			label: 'Kontakt aufnehmen',
			href: 'mailto:db-ux-designsystem@deutschebahn.com',
			variant: 'brand',
		}}
	/>
</DBSection>
