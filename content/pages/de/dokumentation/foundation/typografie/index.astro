---
import DocumentationLayout from '@template/layouts/documentation/DocumentationLayout.astro';
import { DBSection, DBStack } from '@db-ux/react-core-components';
import TypographyPlayground from '../../../../documentation/foundation/typography/_TypographyPlayground.astro';
import TypographyTable from '../../../../documentation/foundation/typography/_TypographyTable.astro';
import GuidelineExample from '@template/components/GuidelineExample/GuidelineExample.astro';
import QuestionForm from '@template/components/QuestionForm/QuestionForm.astro';

// eslint-disable-next-line astro/no-exports-from-components -- Exported for ChildPageOverview glob
export const frontmatter: DocumentationFrontMatter = {
	headline: 'Typografie',
	title: 'Typografie',
	shortDescription: 'Schriftskalen, -stärken und -stile für lesbaren, strukturierten Inhalt.',
	align: 'start',
	toc: true,
	sectionSpacing: 'small',
	sectionWidth: 'auto',
};

const headings = [
	{ depth: 2, slug: 'playground', text: 'Playground' },
	{ depth: 2, slug: 'richtlinien', text: 'Richtlinien' },
	{ depth: 2, slug: 'tokens', text: 'Tokens' },
	{ depth: 2, slug: 'faq', text: 'FAQ' },
];
---

<DocumentationLayout frontmatter={frontmatter} headings={headings}>
	Typografie hilft dabei, Hierarchie zu schaffen und zentrale Inhalte durch klare visuelle Muster zu
	kommunizieren. Gut gestaltete Typografie verbessert die Lesbarkeit und steigert direkt die
	Nutzer:innenerfahrung.

	<DBSection spacing="small">
		<DBStack gap="x-large">
			<DBStack gap="none">
				<h2 id="playground">Playground</h2>
				<br />
				Experimentiere mit Typografie-Tokens, um zu sehen, wie Schriftstile über verschiedene
				Dichten skalieren.
			</DBStack>
			<TypographyPlayground layout="horizontal" />
		</DBStack>
	</DBSection>

	<DBSection spacing="small">
		<h2 id="richtlinien">Richtlinien</h2>

		<h3>Code Mapping</h3>

		<p>
			Unsere Typografie verfügt über ein einfaches und effektives Code-Mapping-System, das die
			gängigsten HTML-Tags (h1, h2, h3, h4, h5, h6, p, small) direkt mit unseren
			Typografie-Tokens 3xs bis 3xl verknüpft. Wenn dies für einen bestimmten Anwendungsfall nicht
			ausreicht, können stattdessen spezifische Tokens verwendet werden.
		</p>

		<div class="guideline-examples">
			<GuidelineExample
				figmaUrl="https://embed.figma.com/design/No7xHLQEEhplMWCiJkIlI8/Doku--Typography?node-id=1-1132&embed-host=share"
				fullWidth={true}
				description="Typografie"
			/>
		</div>
	</DBSection>

	<DBSection spacing="small">
		<h2 id="tokens">Tokens</h2>
		<TypographyTable />
	</DBSection>

	<DBSection spacing="small">
		<h2 id="faq">FAQ</h2>
		<QuestionForm componentName="Typography" />
	</DBSection>

	<script>
		import { waitForElements } from '@template/utils/client.utils.ts';
		import { handleSimplePlaygrounds } from '@content/pages/documentation/foundation/_shared';

		function initTypography(): boolean {
			return handleSimplePlaygrounds({
				dataAttributeName: 'type',
				tokenPrefix: 'type',
				popoverLabel: 'Font',
				withDensity: true,
			});
		}

		waitForElements(initTypography);
	</script>
</DocumentationLayout>
