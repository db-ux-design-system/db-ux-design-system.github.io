---
import DocumentationLayout from '@template/layouts/documentation/DocumentationLayout.astro';
import { DBSection, DBStack } from '@db-ux/react-core-components';
import OpacityPlayground from '../../../../documentation/foundation/opacity/_OpacityPlayground.astro';
import OpacityTable from '../../../../documentation/foundation/opacity/_OpacityTable.astro';
import QuestionForm from '@template/components/QuestionForm/QuestionForm.astro';

// eslint-disable-next-line astro/no-exports-from-components -- Exported for ChildPageOverview glob
export const frontmatter: DocumentationFrontMatter = {
	headline: 'Transparenz',
	title: 'Transparenz',
	shortDescription: 'Transparenzstufen für deaktivierte Zustände und Overlays.',
	align: 'start',
	toc: true,
	sectionSpacing: 'small',
	sectionWidth: 'auto',
};

const headings = [
	{ depth: 2, slug: 'playground', text: 'Playground' },
	{ depth: 2, slug: 'tokens', text: 'Tokens' },
	{ depth: 2, slug: 'faq', text: 'FAQ' },
];
---

<DocumentationLayout frontmatter={frontmatter} headings={headings}>
	Opacity-Tokens bestimmen die Transparenz von Elementen in unserem Design System und beeinflussen
	visuelle Tiefe und Lesbarkeit. Durch sorgfältige Abstufungen der Transparenz können wesentliche
	Informationen hervorgehoben und sekundäre Inhalte abgeschwächt werden.

	<DBSection spacing="small">
		<DBStack gap="x-large">
			<DBStack gap="none">
				<h2 id="playground">Playground</h2>
				<br />
				Experimentiere mit Opacity-Tokens, um zu sehen, wie Transparenz visuelle Elemente
				beeinflusst.
			</DBStack>
			<OpacityPlayground layout="horizontal" />
		</DBStack>
	</DBSection>

	<DBSection spacing="small">
		<h2 id="tokens">Tokens</h2>
		<OpacityTable />
	</DBSection>

	<DBSection spacing="small">
		<h2 id="faq">FAQ</h2>
		<QuestionForm componentName="Opacity" />
	</DBSection>

	<script>
		import { waitForElements } from '@template/utils/client.utils.ts';
		import { handleSimplePlaygrounds } from '@content/pages/documentation/foundation/_shared';

		function initOpacity(): boolean {
			return handleSimplePlaygrounds({
				dataAttributeName: 'opacity',
				tokenPrefix: 'opacity',
				popoverLabel: 'Opacity',
			});
		}

		waitForElements(initOpacity);
	</script>
</DocumentationLayout>
