---
import DocumentationLayout from '@template/layouts/documentation/DocumentationLayout.astro';
import { DBSection, DBStack } from '@db-ux/react-core-components';
import BorderRadiusPlayground from '../../../../documentation/foundation/border-radius/_BorderRadiusPlayground.astro';
import BorderRadiusTable from '../../../../documentation/foundation/border-radius/_BorderRadiusTable.astro';
import QuestionForm from '@template/components/QuestionForm/QuestionForm.astro';

// eslint-disable-next-line astro/no-exports-from-components -- Exported for ChildPageOverview glob
export const frontmatter: DocumentationFrontMatter = {
	headline: 'Eckenradius',
	title: 'Eckenradius',
	shortDescription: 'Abgerundete Ecken für eine konsistente Formensprache über alle Komponenten.',
	align: 'start',
	toc: true,
	sectionSpacing: 'small',
	sectionWidth: 'auto',
};

const headings = [
	{ depth: 2, slug: 'playground', text: 'Playground' },
	{ depth: 2, slug: 'tokens', text: 'Tokens' },
	{ depth: 2, slug: 'faq', text: 'FAQ' },
];
---

<DocumentationLayout frontmatter={frontmatter} headings={headings}>
	Der Border Radius definiert die abgerundeten Ecken von UI-Elementen und beeinflusst die visuelle
	Ästhetik des Design Systems. Diese Tokens ermöglichen konsistente Eckeneigenschaften für eine
	harmonische Interface.

	<DBSection spacing="small">
		<DBStack gap="x-large">
			<DBStack gap="none">
				<h2 id="playground">Playground</h2>
				<br />
				Experimentiere mit Border-Radius-Tokens, um zu sehen, wie sie die Eckenrundung
				beeinflussen.
			</DBStack>
			<BorderRadiusPlayground layout="horizontal" />
		</DBStack>
	</DBSection>

	<DBSection spacing="small">
		<h2 id="tokens">Tokens</h2>
		<BorderRadiusTable />
	</DBSection>

	<DBSection spacing="small">
		<h2 id="faq">FAQ</h2>
		<QuestionForm componentName="Border Radius" />
	</DBSection>

	<script>
		import { waitForElements } from '@template/utils/client.utils.ts';
		import { handleSimplePlaygrounds } from '@content/pages/documentation/foundation/_shared';

		function initBorderRadius(): boolean {
			return handleSimplePlaygrounds({
				dataAttributeName: 'border-radius',
				tokenPrefix: 'border-radius',
				remPx: true,
				popoverLabel: 'Border Radius',
			});
		}

		waitForElements(initBorderRadius);
	</script>
</DocumentationLayout>
