{
  "name": "one-platform",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "prettier --check . && astro check",
    "format": "prettier --write .",
    "update:agent": "npx @db-ux/agent-cli .",
    "lint": "pnpm run \"/lint:.*/\"",
    "lint:eslint": "eslint \"**/*.{js,ts,tsx,astro}\"",
    "lint:stylelint": "stylelint \"**/*.css\" --ignore-path .stylelintignore",
    "cache:figma": "node scripts/cache-figma-images.ts",
    "decode-db-theme-assets": "node decode-db-assets.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:regenerate": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/mdx": "5.0.6",
    "@astrojs/react": "5.0.5",
    "@astrojs/sitemap": "3.7.2",
    "@axe-core/playwright": "4.12.1",
    "@db-ux/agent-cli": "4.14.0-shell-52d18db",
    "@db-ux/core-components": "4.14.0-shell-52d18db",
    "@db-ux/core-eslint-plugin": "4.14.0-shell-52d18db",
    "@db-ux/core-foundations": "4.14.0-shell-52d18db",
    "@db-ux/core-stylelint": "4.14.0-shell-52d18db",
    "@db-ux/db-theme": "5.8.0",
    "@db-ux/db-theme-fonts": "2.0.5",
    "@db-ux/db-theme-icons": "3.9.0",
    "@db-ux/db-theme-illustrative-icons": "3.3.0",
    "@db-ux/react-core-components": "4.14.0-shell-52d18db",
    "@double-great/stylelint-a11y": "3.5.0",
    "@orama/orama": "3.1.18",
    "@orama/plugin-astro": "3.1.18",
    "@playwright/test": "1.61.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.64.0",
    "astro": "6.3.7",
    "eslint": "10.7.0",
    "eslint-plugin-astro": "3.0.1",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "sharp": "0.35.0",
    "stylelint": "17.14.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-use-logical": "2.1.3",
    "typescript": "7.0.2",
    "vite-plugin-static-copy": "3.3.0"
  },
  "dependencies": {
    "@google/model-viewer": "4.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@db-ux/db-theme",
      "@db-ux/db-theme-fonts",
      "@db-ux/db-theme-icons",
      "@db-ux/db-theme-illustrative-icons"
    ],
    "overrides": {
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23"
    }
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
